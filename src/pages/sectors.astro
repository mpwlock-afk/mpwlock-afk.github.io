---
import Base from "../layouts/Base.astro";
import CtaSection from "../components/CtaSection.astro";
import { sectors } from "../data/site";
---

<Base
  title="Hologram Solutions — Hospitality, Retail, Healthcare & Events | Holoconnects"
  description="Holoconnects holographic displays for hospitality, telehealth, retail, events, education and advertising. Life-size interactive holograms for every industry."
>
  <section class="page-hero section--dark">
    <div class="container">
      <p class="eyebrow anim anim-up">Sectors</p>
      <h1 class="display anim anim-up" style="--d:80ms">Where holograms<br /><span class="holo-text">make the difference.</span></h1>
      <p class="lead measure anim anim-up" style="--d:160ms">Leading with hospitality, and at home in telehealth, retail, events, education and advertising.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sector-list">
        {
          sectors.map((s, i) => (
            <article class="srow" data-reveal>
              <div class={`srow-media ${i % 2 === 1 ? "is-right" : ""}`}>
                <img src={s.image} alt={`Hologram for ${s.name} by Holoconnects`} loading="lazy" />
              </div>
              <div class="srow-body">
                <span class="srow-index">{String(i + 1).padStart(2, "0")}</span>
                <h2>{s.name}</h2>
                <p class="lead">{s.blurb}</p>
                <a href={`/sectors/${s.slug}`} class="arrow-link">Explore {s.name.toLowerCase()}
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h9M8 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <CtaSection />
</Base>

<style>
  .page-hero {
    padding-top: clamp(8rem, 14vw, 12rem);
    padding-bottom: clamp(4rem, 8vw, 7rem);
  }
  .page-hero .lead { margin-top: 1.4rem; }
  .sector-list {
    display: flex;
    flex-direction: column;
    gap: clamp(2.5rem, 6vw, 5rem);
  }
  .srow {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .srow-media {
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }
  .srow-media.is-right { order: 2; }
  .srow-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s var(--ease);
  }
  .srow:hover .srow-media img { transform: scale(1.05); }
  .srow-body { display: flex; flex-direction: column; align-items: flex-start; gap: 0.9rem; }
  .srow-index {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--gold);
    letter-spacing: 0.1em;
  }
  .srow-body h2 { font-size: clamp(1.9rem, 4vw, 2.8rem); }
  @media (max-width: 760px) {
    .srow { grid-template-columns: 1fr; gap: 1.25rem; }
    .srow-media.is-right { order: 0; }
  }
</style>
