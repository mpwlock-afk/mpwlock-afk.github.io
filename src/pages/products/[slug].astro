---
import Base from "../../layouts/Base.astro";
import CtaSection from "../../components/CtaSection.astro";
import { products } from "../../data/site";

export function getStaticPaths() {
  return products.map((p) => ({
    params: { slug: p.slug },
    props: { product: p },
  }));
}

const { product } = Astro.props;
const others = products.filter((p) => p.slug !== product.slug).slice(0, 3);

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: product.name,
  description: product.summary,
  image: `https://www.holoconnects.com${product.image}`,
  brand: {
    "@type": "Brand",
    name: "Holoconnects",
  },
  category: "Holographic display",
};
---

<Base
  title={`${product.name} | Holoconnects`}
  description={product.summary}
  image={product.image}
>
  <section class="prod-hero section--dark">
    <div class="container prod-hero-grid">
      <div class="prod-hero-text">
        <p class="eyebrow anim anim-up">{product.name}</p>
        <h1 class="display anim anim-up" style="--d:80ms"><span class="holo-text">{product.tagline}</span></h1>
        <p class="lead anim anim-up" style="--d:160ms">{product.summary}</p>
        <div class="prod-hero-actions anim anim-up" style="--d:240ms">
          <a href="/contact" class="magnetic btn btn--gold">Book a demo</a>
          <a href="/cases" class="magnetic btn btn--ghost">View cases</a>
        </div>
      </div>
      <div class="prod-hero-media anim anim-scale" style="--d:120ms">
        <div class="prod-glow" aria-hidden="true"></div>
        <img src={product.image} alt={`${product.name} holographic display by Holoconnects`} data-parallax="0.06" />
      </div>
    </div>
  </section>

  {
    product.features && (
      <section class="section">
        <div class="container">
          <div class="block-head" data-reveal>
            <p class="eyebrow">Why it works</p>
            <h2 class="section-title">Built to bring real presence into any room.</h2>
          </div>
          <div class="grid cols-2 feat-grid">
            {product.features.map((f, i) => (
              <div class="feat" data-tilt="4" data-reveal style={`--reveal-delay:${(i % 2) * 90}ms`}>
                <span class="feat-num">{String(i + 1).padStart(2, "0")}</span>
                <div>
                  <h3>{f.title}</h3>
                  <p class="text-muted">{f.body}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  {
    product.specs && (
      <section class="section section--soft">
        <div class="container">
          <div class="block-head" data-reveal>
            <p class="eyebrow">Technical details</p>
            <h2 class="section-title">Specifications.</h2>
          </div>
          <div class="spec-grid" data-reveal>
            {product.specs.map((s) => (
              <div class="spec">
                <span class="spec-label">{s.label}</span>
                <span class="spec-value">{s.value}</span>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <section class="section">
    <div class="container">
      <div class="block-head" data-reveal>
        <p class="eyebrow">Keep exploring</p>
        <h2 class="section-title">More from the hologram range.</h2>
      </div>
      <div class="grid cols-3">
        {
          others.map((p, i) => (
            <a href={`/products/${p.slug}`} class="mini-card" data-tilt="6" data-reveal style={`--reveal-delay:${i * 80}ms`}>
              <div class="mini-media"><img src={p.image} alt={p.name} loading="lazy" /></div>
              <div class="mini-body">
                <h3>{p.name}</h3>
                <p class="text-muted">{p.tagline}</p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <CtaSection title={`See the ${product.name} in action`} />

  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
</Base>

<style>
  .prod-hero {
    padding-top: clamp(8rem, 14vw, 12rem);
    padding-bottom: clamp(4rem, 8vw, 7rem);
    overflow: hidden;
  }
  .prod-hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .prod-hero-text .lead {
    margin: 1.4rem 0 2rem;
    max-width: 46ch;
  }
  .prod-hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .prod-hero-media {
    position: relative;
    aspect-ratio: 1;
    display: grid;
    place-items: center;
  }
  .prod-glow {
    position: absolute;
    inset: 10%;
    background: radial-gradient(circle, rgba(200, 120, 0, 0.28), transparent 65%);
    filter: blur(10px);
  }
  .prod-hero-media img {
    position: relative;
    max-height: 520px;
    width: auto;
    object-fit: contain;
    filter: drop-shadow(0 40px 70px rgba(0, 0, 0, 0.55));
  }
  @media (max-width: 820px) {
    .prod-hero-grid { grid-template-columns: 1fr; }
    .prod-hero-media { order: -1; }
    .prod-hero-media img { max-height: 360px; }
  }

  .block-head { max-width: 760px; margin-bottom: clamp(2.5rem, 5vw, 4rem); }

  .feat {
    display: flex;
    gap: 1.25rem;
    padding: 1.5rem;
    border-radius: var(--radius);
    border: 1px solid var(--line);
    transition: border-color 0.4s, transform 0.4s;
  }
  .feat:hover { border-color: var(--line-strong); transform: translateY(-3px); }
  .feat-num {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--gold);
    font-size: 1.1rem;
  }
  .feat h3 { font-size: 1.25rem; margin-bottom: 0.4rem; }

  .spec-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .spec {
    background: var(--surface);
    padding: 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .spec-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--grey-soft);
  }
  .spec-value {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--ink);
  }
  @media (max-width: 760px) {
    .spec-grid { grid-template-columns: 1fr 1fr; }
  }

  .mini-card {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--surface);
    box-shadow: var(--shadow-card);
    transition: transform 0.4s var(--ease);
  }
  .mini-card:hover { transform: translateY(-5px); }
  .mini-media {
    aspect-ratio: 4 / 3;
    background: radial-gradient(circle at 50% 40%, #1a1a1d, #0a0a0a);
    display: grid;
    place-items: center;
  }
  .mini-media img { width: 100%; height: 100%; object-fit: contain; padding: 1.5rem; }
  .mini-body { padding: 1.4rem; }
  .mini-body h3 { font-size: 1.3rem; margin-bottom: 0.3rem; }
</style>
