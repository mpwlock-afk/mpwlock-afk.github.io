---
import Base from "../../layouts/Base.astro";
import CtaSection from "../../components/CtaSection.astro";
import { products } from "../../data/site";

const itemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Holoconnects holographic display range",
  itemListElement: products.map((p, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: p.name,
    url: `https://www.holoconnects.com/products/${p.slug}`,
  })),
};
---

<Base
  title="Hologram Displays & Holobox Range | Holoconnects"
  description="Discover the Holoconnects holographic display range: the Holobox, Holobox Mini, the 43 inch hologram box, Hologrid wall and AI hologram host. Book a demo today."
>
  <section class="page-hero section--dark">
    <div class="container">
      <p class="eyebrow anim anim-up">Our products</p>
      <h1 class="display anim anim-up" style="--d:80ms">The hologram<br /><span class="holo-text">product range.</span></h1>
      <p class="lead measure anim anim-up" style="--d:160ms">One platform for every display, from the 86&quot; Holobox to AI-driven holograms.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="prod-list">
        {
          products.map((p, i) => (
            <article class="prow" data-reveal>
              <div class={`prow-media ${i % 2 === 1 ? "is-right" : ""}`}>
                <img src={p.image} alt={`${p.name} holographic display`} loading="lazy" />
              </div>
              <div class="prow-body">
                <p class="pill">{p.tagline}</p>
                <h2>{p.name}</h2>
                <p class="text-muted">{p.summary}</p>
                <a href={`/products/${p.slug}`} class="btn btn--primary">Explore the {p.name}</a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <CtaSection />

  <script type="application/ld+json" set:html={JSON.stringify(itemList)} />
</Base>

<style>
  .page-hero {
    padding-top: clamp(8rem, 14vw, 12rem);
    padding-bottom: clamp(4rem, 8vw, 7rem);
  }
  .page-hero .lead {
    margin-top: 1.4rem;
  }
  .prod-list {
    display: flex;
    flex-direction: column;
    gap: clamp(3rem, 7vw, 6rem);
  }
  .prow {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }
  .prow-media {
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: radial-gradient(circle at 50% 40%, #1a1a1d, #0a0a0a);
    aspect-ratio: 5 / 4;
    display: grid;
    place-items: center;
  }
  .prow-media.is-right {
    order: 2;
  }
  .prow-media img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 2rem;
  }
  .prow-body {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }
  .prow-body h2 {
    font-size: clamp(2rem, 4vw, 3rem);
  }
  .prow-body .btn {
    margin-top: 0.6rem;
  }
  @media (max-width: 760px) {
    .prow {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .prow-media.is-right {
      order: 0;
    }
  }
</style>
