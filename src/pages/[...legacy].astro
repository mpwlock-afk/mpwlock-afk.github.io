---
// Static redirect stubs for legacy WordPress URLs. Catch-all has the LOWEST
// route priority in Astro, so it never shadows a real page — it only fires for
// paths that would otherwise 404. Each stub carries rel=canonical to the new
// target so link equity consolidates, plus meta-refresh + JS for the user.
import { redirects } from "../data/redirects";

export function getStaticPaths() {
  return redirects.map((r) => ({
    // strip the leading slash → catch-all param
    params: { legacy: r.from.replace(/^\//, "") },
    props: { to: r.to },
  }));
}

const { to } = Astro.props;
const site = Astro.site ?? new URL("https://www.holoconnects.com");
const target = new URL(to, site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Redirecting…</title>
    <link rel="canonical" href={target} />
    <meta http-equiv="refresh" content={`0; url=${to}`} />
    <meta name="robots" content="noindex, follow" />
    <script is:inline set:html={`location.replace(${JSON.stringify(to)})`} />
  </head>
  <body>
    <p>This page has moved. Redirecting to <a href={to}>{to}</a>…</p>
  </body>
</html>
