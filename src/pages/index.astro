---
import Base from "../layouts/Base.astro";
import CtaSection from "../components/CtaSection.astro";
import { products, sectors, stats, testimonials } from "../data/site";

const marqueeItems = [
  "Hospitality",
  "Telehealth",
  "Retail",
  "Events",
  "Education",
  "Advertising",
];

const productListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Holoconnects hologram display range",
  description:
    "Interactive, life-size holographic displays from Holoconnects, including the Holobox, Holobox Mini, The 43, Hologrid and AI Hologram.",
  itemListElement: products.map((p, i) => ({
    "@type": "ListItem",
    position: i + 1,
    item: {
      "@type": "Product",
      name: p.name,
      description: p.summary,
      url: `https://www.holoconnects.com/products/${p.slug}`,
      image: new URL(p.image, "https://www.holoconnects.com").href,
      brand: { "@type": "Brand", name: "Holoconnects" },
    },
  })),
};
---

<Base
  title="Holoconnects | Interactive Life-Size Hologram Displays"
  description="Holoconnects builds interactive, life-size holographic displays. Meet the Holobox and our hologram range, bringing a real human presence anywhere, 24/7."
>
  <!-- ============ HERO ============ -->
  <section class="hero">
    <canvas id="holo-canvas" class="hero-canvas" aria-hidden="true"></canvas>
    <div class="hero-mesh" aria-hidden="true"></div>
    <div class="hero-scan" aria-hidden="true"></div>

    <div class="container hero-content" data-depth>
      <span class="hero-tag">
        <span class="hero-tag-dot"></span>Innovation with a human touch
      </span>
      <h1 class="hero-title">
        <span class="kinetic" data-split>Real people,</span>
        <span class="hero-rotator">
          <span class="holo-text">real connections.</span>
          <span class="holo-text">24/7 hospitality.</span>
          <span class="holo-text">life-size presence.</span>
          <span class="holo-text">global reach.</span>
        </span>
      </h1>
      <p class="hero-sub anim anim-up" style="--d:500ms">
        Life-size, interactive holograms that bring a human presence anywhere.
      </p>
      <div class="hero-actions anim anim-up" style="--d:640ms">
        <a href="/demo" class="magnetic btn btn--gold">Book a demo</a>
        <a href="/products/holobox" class="magnetic btn btn--ghost-light">Discover the Holobox</a>
      </div>
    </div>

    <div class="hero-foot">
      <span class="hero-foot-rating">★ 9.5/10 · 346 reviews</span>
      <span class="hero-scrollcue">Scroll to explore<span class="hero-scrollcue-line"></span></span>
    </div>
  </section>

  <!-- ============ MARQUEE ============ -->
  <section class="marquee-band">
    <div class="marquee" data-speed="0.5">
      <div class="marquee__track">
        {
          marqueeItems.map((m) => (
            <span class="marquee__item">
              {m}<span class="marquee__dot">✦</span>
            </span>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ STATS ============ -->
  <section class="section stats-sec">
    <div class="container">
      <div class="stats-row">
        {
          stats.map((s) => (
            <div class="stat-cell anim anim-up">
              <span class="stat-num" data-count={s.value}>{s.value}</span>
              <span class="stat-cap">{s.label}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ HOSPITALITY SHOWCASE ============ -->
  <section class="hospo">
    <div class="hospo__media">
      <img src="/images/sector-hospitality.jpg" alt="Life-size holographic concierge welcoming a guest in a hotel lobby" data-parallax="0.12" />
    </div>
    <div class="hospo__veil"></div>
    <div class="container hospo__content">
      <span class="eyebrow anim anim-up">Flagship · Hospitality</span>
      <h2 class="hospo__title anim anim-up" style="--d:80ms">
        The 24/7 holographic<br /><span class="holo-text">concierge.</span>
      </h2>
      <p class="hospo__lead anim anim-up" style="--d:160ms">
        One host. Every lobby. A welcome that never sleeps.
      </p>
      <a href="/sectors" class="magnetic btn btn--gold anim anim-up" style="--d:240ms">Explore hospitality</a>
    </div>
    <div class="hospo__stats">
      <div class="hospo__stat anim anim-up"><span>-40%</span><small>Front-desk costs</small></div>
      <div class="hospo__stat anim anim-up" style="--d:90ms"><span>24/7</span><small>Guest presence</small></div>
      <div class="hospo__stat anim anim-up" style="--d:180ms"><span>30+</span><small>Hotels live</small></div>
    </div>
  </section>

  <!-- ============ PINNED HORIZONTAL PRODUCTS ============ -->
  <section class="hpin section--dark" data-hscroll>
    <div class="hpin__sticky">
      <div class="container hpin__head">
        <span class="eyebrow">The ecosystem</span>
        <h2 class="hpin__title">Scroll the<br /><span class="holo-text">hologram range.</span></h2>
      </div>
      <div class="hpin__track">
        <div class="hpin__intro">
          <p class="lead">One platform powers every display, from a life-size 86&quot; Holobox to a desktop Mini, modular walls and AI-driven holograms.</p>
          <span class="hpin__hint">Keep scrolling →</span>
        </div>
        {
          products.map((p, i) => (
            <a href={`/products/${p.slug}`} class="hcard hoverable" data-tilt="5">
              <span class="hcard__index">{String(i + 1).padStart(2, "0")}</span>
              <div class="hcard__media">
                <div class="hcard__glow"></div>
                <img src={p.image} alt={`${p.name} interactive hologram display by Holoconnects`} loading="lazy" />
              </div>
              <div class="hcard__body">
                <h3>{p.name}</h3>
                <p>{p.tagline}</p>
                <span class="arrow-link">Explore
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h9M8 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ VALUES ============ -->
  <section class="section values-sec">
    <div class="container">
      <p class="eyebrow anim anim-up">Why Holoconnects</p>
      <h2 class="big-statement reveal-lines">
        <span class="line"><span style="--i:0">Technology that brings</span></span>
        <span class="line"><span style="--i:1">people <em class="holo-text">closer</em>, not</span></span>
        <span class="line"><span style="--i:2">screens between them.</span></span>
      </h2>
      <div class="values-grid">
        <div class="value-block anim anim-up" data-tilt="4">
          <span class="value-no">01</span>
          <h3>A human touch</h3>
          <p>Technology that deepens human connection instead of replacing it.</p>
        </div>
        <div class="value-block anim anim-up" style="--d:120ms" data-tilt="4">
          <span class="value-no">02</span>
          <h3>Real presence</h3>
          <p>A genuinely personal presence in any virtual space.</p>
        </div>
        <div class="value-block anim anim-up" style="--d:240ms" data-tilt="4">
          <span class="value-no">03</span>
          <h3>Sustainable reach</h3>
          <p>Broader reach with a lower footprint, inclusive by design.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ SECTORS (parallax) ============ -->
  <section class="section section--dark sectors-sec">
    <div class="container">
      <div class="sectors-head">
        <h2 class="section-title anim anim-up">Built for the moments<br />that matter.</h2>
        <p class="lead anim anim-up" style="--d:120ms">From guest experiences in hospitality to virtual care in telehealth, we deliver lifelike presence where it counts.</p>
      </div>
      <div class="sectors-stack">
        {
          sectors.map((s, i) => (
            <a href="/sectors" class="sec-tile hoverable anim anim-scale" style={`--d:${(i % 3) * 90}ms`}>
              <div class="sec-tile__img">
                <img src={s.image} alt={`Holoconnects holographic displays for ${s.name}`} data-parallax="0.08" loading="lazy" />
              </div>
              <div class="sec-tile__veil"></div>
              <div class="sec-tile__txt">
                <span class="sec-tile__no">0{i + 1}</span>
                <h3>{s.name}</h3>
                <p>{s.blurb}</p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ TESTIMONIAL ============ -->
  <section class="section testi-sec">
    <div class="container">
      <div class="testi-head">
        <p class="eyebrow anim anim-up">Trusted worldwide</p>
        <h2 class="section-title anim anim-up" style="--d:80ms">What our clients say.</h2>
      </div>
      <div class="testi-grid">
        {
          testimonials.map((t, i) => (
            <figure class="testi-card anim anim-up" style={`--d:${i * 90}ms`} data-tilt="3">
              <div class="testi-media">
                <img src={t.image} alt={`Holoconnects hologram in use, project by ${t.name}`} loading="lazy" />
              </div>
              <div class="testi-body">
                <span class="testi-mark holo-text" aria-hidden="true">&ldquo;</span>
                <blockquote>{t.quote}</blockquote>
                <figcaption>
                  <strong>{t.name}</strong>
                  <span>{t.role}</span>
                </figcaption>
              </div>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <CtaSection />

  <script type="application/ld+json" set:html={JSON.stringify(productListSchema)} />
</Base>

<style>
  /* ============ HERO ============ */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: clamp(7rem, 14vh, 10rem);
    padding-bottom: clamp(4rem, 8vh, 6rem);
    background: #050507;
    color: #fff;
    overflow: hidden;
  }
  .hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }
  .hero-mesh {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      radial-gradient(55% 65% at 82% 40%, rgba(234, 153, 20, 0.25), transparent 60%),
      radial-gradient(45% 55% at 12% 85%, rgba(200, 120, 0, 0.14), transparent 60%),
      linear-gradient(95deg, rgba(5, 5, 7, 0.92) 18%, rgba(5, 5, 7, 0.45) 46%, transparent 66%),
      radial-gradient(120% 100% at 50% 0%, transparent 40%, rgba(5, 5, 7, 0.6) 100%);
    animation: meshDrift 14s ease-in-out infinite alternate;
  }
  @keyframes meshDrift {
    to { transform: translate3d(-3%, 2%, 0) scale(1.08); }
  }
  .hero-scan {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: repeating-linear-gradient(
      to bottom,
      rgba(255, 255, 255, 0.025) 0px,
      rgba(255, 255, 255, 0.025) 1px,
      transparent 1px,
      transparent 4px
    );
    mix-blend-mode: overlay;
    opacity: 0.5;
  }
  .hero-content {
    position: relative;
    z-index: 3;
    max-width: 1180px;
  }
  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    padding: 0.55rem 1.05rem;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 100px;
    margin-bottom: 1.8rem;
    backdrop-filter: blur(6px);
    opacity: 0;
    animation: fadeDown 0.9s var(--ease) 0.1s forwards;
  }
  .hero-tag-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--grad-gold);
    box-shadow: 0 0 12px 2px rgba(234, 153, 20, 0.8);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    50% { opacity: 0.4; transform: scale(0.8); }
  }
  @keyframes fadeDown {
    from { opacity: 0; transform: translateY(-12px); }
    to { opacity: 1; transform: none; }
  }

  .hero-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.6rem, 6vw, 5.4rem);
    line-height: 1.0;
    letter-spacing: -0.04em;
    margin: 0 0 1.6rem;
    color: #fff;
    max-width: 66vw;
    position: relative;
    z-index: 4;
  }
  .hero-title .kinetic {
    display: block;
    white-space: nowrap;
  }
  @media (max-width: 900px) {
    .hero-title { max-width: 100%; }
  }
  .hero-rotator {
    display: inline-grid;
    overflow: hidden;
    vertical-align: top;
    padding-bottom: 0.12em;
    white-space: nowrap;
  }
  .hero-rotator > span {
    grid-area: 1 / 1;
    white-space: nowrap;
    opacity: 0;
    transform: translateY(0.7em) rotateX(-40deg);
    animation: rotWord 12s cubic-bezier(0.16, 1, 0.3, 1) infinite;
  }
  .hero-rotator > span:nth-child(1) { animation-delay: 0.6s; }
  .hero-rotator > span:nth-child(2) { animation-delay: 3.6s; }
  .hero-rotator > span:nth-child(3) { animation-delay: 6.6s; }
  .hero-rotator > span:nth-child(4) { animation-delay: 9.6s; }
  @keyframes rotWord {
    0% { opacity: 0; transform: translateY(0.7em) rotateX(-40deg); }
    4%, 21% { opacity: 1; transform: none; }
    25%, 100% { opacity: 0; transform: translateY(-0.7em) rotateX(40deg); }
  }

  .hero-sub {
    max-width: 44ch;
    font-size: clamp(1.05rem, 1.6vw, 1.3rem);
    color: #c4c4cd;
    line-height: 1.55;
    margin-bottom: 2.2rem;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .btn--ghost-light {
    background: transparent;
    color: #fff;
    border-color: rgba(255, 255, 255, 0.28);
  }
  .btn--ghost-light:hover {
    border-color: #fff;
    background: rgba(255, 255, 255, 0.06);
  }

  .hero-foot {
    position: absolute;
    bottom: 1.8rem;
    left: 0;
    right: 0;
    z-index: 3;
    padding-inline: var(--gutter);
    max-width: var(--maxw);
    margin-inline: auto;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
  }
  .hero-foot-rating {
    color: var(--gold-bright);
  }
  .hero-scrollcue {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }
  .hero-scrollcue-line {
    width: 46px;
    height: 1px;
    background: rgba(255, 255, 255, 0.4);
    position: relative;
    overflow: hidden;
  }
  .hero-scrollcue-line::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--gold-bright);
    animation: cueSlide 2s ease-in-out infinite;
  }
  @keyframes cueSlide {
    0% { transform: translateX(-100%); }
    60%, 100% { transform: translateX(100%); }
  }
  @media (max-width: 640px) {
    .hero-foot-rating { display: none; }
  }

  /* ============ MARQUEE ============ */
  .marquee-band {
    background: var(--ink);
    color: #fff;
    padding-block: clamp(1.4rem, 3vw, 2.4rem);
    border-block: 1px solid rgba(255, 255, 255, 0.08);
  }
  .marquee-band .marquee__item {
    font-size: clamp(1.8rem, 4vw, 3.2rem);
    color: rgba(255, 255, 255, 0.32);
    text-transform: uppercase;
  }
  .marquee-band .marquee__dot {
    margin-left: 3rem;
    font-size: 0.6em;
  }

  /* ============ STATS ============ */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  .stat-cell {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1.5rem 0;
    border-top: 1px solid var(--line);
  }
  .stat-num {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 6vw, 4.5rem);
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--ink);
  }
  .stat-cap {
    font-size: 0.9rem;
    color: var(--grey);
  }
  @media (max-width: 620px) {
    .stats-row { grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  }

  /* ============ HOSPITALITY ============ */
  .hospo {
    position: relative;
    min-height: 92vh;
    min-height: 92svh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    color: #fff;
    isolation: isolate;
    padding-bottom: clamp(2rem, 5vw, 4rem);
  }
  .hospo__media {
    position: absolute;
    inset: -10% 0;
    z-index: -2;
  }
  .hospo__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hospo__veil {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(to top, rgba(5, 5, 7, 0.95) 4%, rgba(5, 5, 7, 0.3) 45%, rgba(5, 5, 7, 0.55) 100%),
      radial-gradient(70% 60% at 20% 90%, rgba(200, 120, 0, 0.25), transparent 70%);
  }
  .hospo__content {
    position: relative;
    z-index: 1;
  }
  .hospo__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.6rem, 7vw, 6rem);
    line-height: 0.96;
    letter-spacing: -0.04em;
    color: #fff;
    margin: 0.8rem 0 1rem;
  }
  .hospo__lead {
    font-size: clamp(1.15rem, 2vw, 1.6rem);
    color: #e0e0e6;
    margin-bottom: 2rem;
    font-weight: 400;
  }
  .hospo__stats {
    position: relative;
    z-index: 1;
    max-width: var(--maxw);
    margin: clamp(2.5rem, 5vw, 4rem) auto 0;
    width: 100%;
    padding-inline: var(--gutter);
    display: flex;
    gap: clamp(2rem, 6vw, 5rem);
    flex-wrap: wrap;
  }
  .hospo__stat span {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.2rem, 4vw, 3.4rem);
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--gold-bright);
  }
  .hospo__stat small {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
  }

  /* ============ PINNED HORIZONTAL ============ */
  .hpin {
    position: relative;
    overflow: hidden;
  }
  .hpin__sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    height: 100svh;
    overflow: hidden;
    clip-path: inset(0 0 0 0); /* force-clip GPU-composited translate3d children */
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .hpin__head {
    position: absolute;
    top: clamp(5rem, 12vh, 9rem);
    left: 0;
    right: 0;
    z-index: 2;
    pointer-events: none;
  }
  .hpin__title {
    font-size: clamp(2rem, 5vw, 3.8rem);
    color: #fff;
  }
  .hpin__track {
    display: flex;
    align-items: center;
    gap: clamp(1.5rem, 3vw, 2.5rem);
    padding-inline: var(--gutter);
    height: 100%;
    will-change: transform;
  }
  .hpin__intro {
    flex: 0 0 auto;
    width: min(80vw, 420px);
    align-self: center;
    padding-top: 6rem;
  }
  .hpin__intro .lead {
    color: #cfcfd6;
  }
  .hpin__hint {
    display: inline-block;
    margin-top: 1.2rem;
    color: var(--gold-bright);
    font-size: 0.8rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .hcard {
    flex: 0 0 auto;
    width: min(78vw, 380px);
    height: min(64vh, 540px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.01));
    padding: 1.8rem;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    transition: border-color 0.5s var(--ease), transform 0.5s var(--ease);
  }
  .hcard:hover {
    border-color: rgba(234, 153, 20, 0.5);
    transform: translateY(-6px);
  }
  .hcard__index {
    font-family: var(--font-display);
    font-size: 0.85rem;
    color: var(--gold-bright);
    letter-spacing: 0.12em;
  }
  .hcard__media {
    position: relative;
    flex: 1 1 0; /* take the remaining space, never the image's intrinsic height */
    min-height: 0;
    overflow: hidden; /* keep the render inside the frame */
    display: grid;
    place-items: center;
    margin: 0.5rem 0 1rem;
  }
  .hcard__body {
    flex: 0 0 auto; /* body keeps its full height; title, tagline & link always visible */
  }
  .hcard__glow {
    position: absolute;
    inset: 12% 18%;
    background: radial-gradient(circle, rgba(234, 153, 20, 0.4), transparent 65%);
    filter: blur(14px);
  }
  .hcard__media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 24px 40px rgba(0, 0, 0, 0.5));
  }
  .hcard__body h3 {
    color: #fff;
    font-size: 1.7rem;
    margin-bottom: 0.4rem;
  }
  .hcard__body p {
    color: #b4b4bd;
    font-size: 0.95rem;
    margin-bottom: 0.9rem;
  }
  @media (max-width: 760px) {
    /* On small screens, fall back to natural horizontal swipe */
    .hpin { height: auto !important; }
    .hpin__sticky { position: static; height: auto; padding-block: 6rem 4rem; }
    .hpin__track {
      transform: none !important;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      padding-bottom: 1rem;
    }
    .hpin__head { position: static; margin-bottom: 2rem; }
    .hcard { scroll-snap-align: center; height: 70vh; }
  }

  /* ============ VALUES ============ */
  .big-statement {
