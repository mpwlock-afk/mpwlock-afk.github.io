---
import Base from "../layouts/Base.astro";
import CtaSection from "../components/CtaSection.astro";
import { stats } from "../data/site";
---

<Base
  title="About Holoconnects — Europe's Leading Hologram Technology Company"
  description="Founded by André and Marnix. 470+ projects, 30+ countries, 9.5/10 customer rating."
>
  <section class="page-hero section--dark">
    <div class="container">
      <p class="eyebrow anim anim-up">About us</p>
      <h1 class="display anim anim-up" style="--d:80ms">Innovation with<br /><span class="holo-text">a human touch.</span></h1>
      <p class="lead measure anim anim-up" style="--d:160ms">Europe's leading hologram company — built on a belief in real, human connection.</p>
    </div>
  </section>

  <section class="section">
    <div class="container story">
      <div class="story-text anim anim-up">
        <p class="eyebrow">Our story</p>
        <h2 class="section-title">It started with<br />a <span class="holo-text">human idea.</span></h2>
        <p>Founders Andre and Marnix set out to keep people &ldquo;in touch&rdquo; across any distance. When Covid-19 hit, they went all in on holographic presence.</p>
        <p class="text-muted">Everything is built in-house for quality — 20 to 30 units a month, and growing.</p>
      </div>
      <div class="story-media anim anim-scale" style="--d:120ms">
        <img src="/images/setup.jpg" alt="Holoconnects team installing a life-size Holobox hologram display" loading="lazy" />
      </div>
    </div>
  </section>

  <section class="section--tight stats-band">
    <div class="container">
      <div class="stats-grid">
        {
          stats.map((s, i) => (
            <div class="stat" data-reveal style={`--reveal-delay:${i * 90}ms`}>
              <span class="stat-value">{s.value}</span>
              <span class="stat-label">{s.label}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container">
      <div class="block-head center" data-reveal>
        <p class="eyebrow">What we stand for</p>
        <h2 class="section-title">A future where technology and<br />human interaction go hand in hand.</h2>
      </div>
      <div class="grid cols-3 values-grid">
        <div class="value" data-reveal>
          <h3>Innovation with a human touch</h3>
          <p>Technology that enhances human connection and promotes sustainable business — without losing authentic interaction.</p>
        </div>
        <div class="value" data-reveal style="--reveal-delay:90ms">
          <h3>Inclusive sustainability</h3>
          <p>Helping businesses across every sector reach a broader audience in an environmentally friendly, inclusive way.</p>
        </div>
        <div class="value" data-reveal style="--reveal-delay:180ms">
          <h3>Real people, real connections</h3>
          <p>A genuinely personal presence in virtual spaces — technology as a complement to the human experience, never a replacement.</p>
        </div>
      </div>
    </div>
  </section>

  <CtaSection />
</Base>

<style>
  .page-hero {
    padding-top: clamp(8rem, 14vw, 12rem);
    padding-bottom: clamp(4rem, 8vw, 7rem);
  }
  .page-hero .lead { margin-top: 1.4rem; }

  .story {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }
  .story-text h2 { margin-bottom: 1.5rem; }
  .story-text p { font-size: 1.08rem; line-height: 1.7; }
  .story-media {
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 4 / 5;
  }
  .story-media img { width: 100%; height: 100%; object-fit: cover; }
  @media (max-width: 820px) {
    .story { grid-template-columns: 1fr; }
    .story-media { order: -1; aspect-ratio: 16 / 10; }
  }

  .stats-band { border-block: 1px solid var(--line); }
  .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; }
  .stat { display: flex; flex-direction: column; gap: 0.3rem; padding: 1rem 0; }
  .stat-value {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 4vw, 3.4rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1;
    background: var(--grad-gold);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .stat-label { font-size: 0.9rem; color: var(--grey); }
  @media (max-width: 620px) { .stats-grid { grid-template-columns: 1fr 1fr; gap: 1.5rem; } }

  .block-head { max-width: 820px; margin-bottom: clamp(2.5rem, 5vw, 4rem); }
  .block-head.center { margin-inline: auto; text-align: center; }

  .value {
    padding: 2rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.02);
    transition: border-color 0.4s, background 0.4s;
  }
  .value:hover { border-color: rgba(200, 120, 0, 0.4); background: rgba(200, 120, 0, 0.04); }
  .value h3 { font-size: 1.3rem; margin-bottom: 0.7rem; }
</style>
