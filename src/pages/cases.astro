---
import Base from "../layouts/Base.astro";
import CtaSection from "../components/CtaSection.astro";
import { cases, testimonials } from "../data/site";
---

<Base title="Cases — Holoconnects" description="They already chose Holoconnects. Discover holographic projects with BMW, ING, Visit Britain and more.">
  <section class="page-hero section--dark">
    <div class="container">
      <p class="eyebrow anim anim-up">Cases</p>
      <h1 class="display anim anim-up" style="--d:80ms">They already chose<br /><span class="holo-text">Holoconnects.</span></h1>
      <p class="lead measure anim anim-up" style="--d:160ms">From global brands to government missions.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="case-grid">
        {
          cases.map((c, i) => (
            <article class={`case ${i === 0 ? "case--wide" : ""}`} data-tilt="4" data-reveal style={`--reveal-delay:${(i % 3) * 70}ms`}>
              <img src={c.image} alt={c.title} loading="lazy" />
              <div class="case-overlay"></div>
              <div class="case-text">
                <span class="case-sector">{c.sector}</span>
                <h3>{c.title}</h3>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <div class="block-head" data-reveal>
        <p class="eyebrow">In their words</p>
        <h2 class="section-title">What our clients say.</h2>
      </div>
      <div class="grid cols-3">
        {
          testimonials.map((t, i) => (
            <figure class="quote-card" data-reveal style={`--reveal-delay:${i * 90}ms`}>
              <blockquote>&ldquo;{t.quote}&rdquo;</blockquote>
              <figcaption>
                <img src={t.image} alt="" loading="lazy" />
                <span><strong>{t.name}</strong><small>{t.role}</small></span>
              </figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <CtaSection title="Curious how our technology adds value for you?" />
</Base>

<style>
  .page-hero {
    padding-top: clamp(8rem, 14vw, 12rem);
    padding-bottom: clamp(4rem, 8vw, 7rem);
  }
  .page-hero .lead { margin-top: 1.4rem; }

  .case-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .case {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    display: flex;
    align-items: flex-end;
    isolation: isolate;
  }
  .case--wide { grid-column: span 2; }
  .case img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -2;
    transition: transform 0.8s var(--ease);
  }
  .case:hover img { transform: scale(1.06); }
  .case-overlay {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(to top, rgba(8, 8, 10, 0.9), rgba(8, 8, 10, 0.1) 70%);
  }
  .case-text { padding: 1.6rem; color: #fff; }
  .case-sector {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gold-bright);
  }
  .case-text h3 { color: #fff; font-size: 1.4rem; margin-top: 0.3rem; }

  .block-head { max-width: 760px; margin-bottom: clamp(2.5rem, 5vw, 4rem); }

  .quote-card {
    margin: 0;
    padding: 2rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    box-shadow: var(--shadow-card);
  }
  .quote-card blockquote { margin: 0; font-size: 1.1rem; line-height: 1.55; font-weight: 500; }
  .quote-card figcaption { display: flex; align-items: center; gap: 0.9rem; margin-top: auto; }
  .quote-card figcaption img { width: 48px; height: 48px; border-radius: 50%; object-fit: cover; }
  .quote-card figcaption span { display: flex; flex-direction: column; }
  .quote-card figcaption small { color: var(--grey); font-size: 0.85rem; }

  @media (max-width: 760px) {
    .case-grid { grid-template-columns: 1fr 1fr; }
    .case--wide { grid-column: span 2; }
  }
  @media (max-width: 520px) {
    .case-grid { grid-template-columns: 1fr; }
    .case--wide { grid-column: auto; }
  }
</style>
