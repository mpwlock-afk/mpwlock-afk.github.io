---
import Base from "../layouts/Base.astro";
import { site } from "../data/site";

const calendly =
  "https://calendly.com/mpw-lock/30min?hide_gdpr_banner=1&background_color=0a0a0a&text_color=ffffff&primary_color=ea9914";
---

<Base title="Book a demo — Holoconnects" description="Schedule a live 30-minute Holobox demo directly in our calendar.">
  <section class="page-hero section--dark">
    <div class="container">
      <p class="eyebrow anim anim-up">Book a demo</p>
      <h1 class="display anim anim-up" style="--d:80ms">See it <span class="holo-text">life-size.</span></h1>
      <p class="lead measure anim anim-up" style="--d:160ms">
        Pick a slot. 30 minutes with our team, live on a Holobox.
      </p>
    </div>
  </section>

  <section class="section section--dark demo-sec">
    <div class="container demo-grid">
      <div class="demo-cal anim anim-scale" style="--d:120ms">
        <iframe
          src={calendly}
          title="Schedule a Holoconnects demo"
          loading="lazy"
          data-lenis-prevent
        ></iframe>
      </div>
      <aside class="demo-side">
        <div class="demo-point anim anim-up" style="--d:200ms">
          <span class="demo-num holo-text">01</span>
          <div>
            <h3>Live, not a video</h3>
            <p>We broadcast in real time, so you experience the presence first-hand.</p>
          </div>
        </div>
        <div class="demo-point anim anim-up" style="--d:280ms">
          <span class="demo-num holo-text">02</span>
          <div>
            <h3>Tailored to your sector</h3>
            <p>Hospitality, retail, events or telehealth, we demo your use case.</p>
          </div>
        </div>
        <div class="demo-point anim anim-up" style="--d:360ms">
          <span class="demo-num holo-text">03</span>
          <div>
            <h3>Honest advice</h3>
            <p>Buy, rent or lease. We'll tell you what fits, with real numbers.</p>
          </div>
        </div>
        <div class="demo-alt anim anim-up" style="--d:440ms">
          <p>Prefer email or phone?</p>
          <a href={`mailto:${site.email}`}>{site.email}</a>
          <a href={`tel:${site.phoneHref}`}>{site.phone}</a>
        </div>
      </aside>
    </div>
  </section>
</Base>

<style>
  .page-hero {
    padding-top: clamp(8rem, 14vw, 12rem);
    padding-bottom: clamp(2rem, 4vw, 3rem);
  }
  .page-hero .lead { margin-top: 1.4rem; }

  .demo-sec { padding-top: 0; }
  .demo-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: start;
  }
  .demo-cal {
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: #0a0a0a;
    box-shadow: 0 40px 90px -40px rgba(200, 120, 0, 0.25);
  }
  .demo-cal iframe {
    display: block;
    width: 100%;
    height: 760px;
    border: 0;
  }
  .demo-side {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
    position: sticky;
    top: 7rem;
  }
  .demo-point {
    display: flex;
    gap: 1.1rem;
    padding: 1.4rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.03);
  }
  .demo-num {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: 0.08em;
  }
  .demo-point h3 {
    color: #fff;
    font-size: 1.15rem;
    margin-bottom: 0.35rem;
  }
  .demo-point p {
    color: #a6a6ae;
    margin: 0;
    font-size: 0.95rem;
  }
  .demo-alt {
    padding: 1.4rem;
    border-radius: var(--radius);
    background: var(--grad-gold);
    color: #0a0a0a;
  }
  .demo-alt p {
    font-weight: 700;
    margin-bottom: 0.4rem;
  }
  .demo-alt a {
    display: block;
    font-weight: 600;
    padding: 0.15rem 0;
  }
  .demo-alt a:hover { text-decoration: underline; }

  @media (max-width: 860px) {
    .demo-grid { grid-template-columns: 1fr; }
    .demo-side { position: static; }
    .demo-cal iframe { height: 640px; }
  }
</style>
