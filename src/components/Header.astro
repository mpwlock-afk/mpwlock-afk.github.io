---
import { nav } from "../data/site";
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header class="site-header" id="site-header" data-transparent>
  <div class="header-inner">
    <a href="/" class="brand" aria-label="Holoconnects home">
      <img class="brand-mark" src="/images/logo-mark.png" alt="" width="28" height="28" />
      <span class="brand-name">holoconnects</span>
    </a>

    <nav class="primary-nav" aria-label="Primary">
      {
        nav.map((item) =>
          item.children ? (
            <div class="nav-item has-menu">
              <a href={item.href} class:list={["nav-link", { active: isActive(item.href) }]}>
                {item.label}
                <svg width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              </a>
              <div class="dropdown">
                <div class="dropdown-inner">
                  {item.children.map((c) => (
                    <a href={c.href} class="dropdown-link">{c.label}</a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a href={item.href} class:list={["nav-link", { active: isActive(item.href) }]}>
              {item.label}
            </a>
          )
        )
      }
    </nav>

    <div class="header-actions">
      <a href="/demo" class="btn btn--primary btn--sm">Book a demo</a>
    </div>

    <button class="menu-toggle" id="menu-toggle" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="mobile-menu" id="mobile-menu">
    {
      nav.map((item) => (
        <div class="mobile-group">
          <a href={item.href} class="mobile-link">{item.label}</a>
          {item.children && (
            <div class="mobile-sub">
              {item.children.map((c) => (
                <a href={c.href} class="mobile-sublink">{c.label}</a>
              ))}
            </div>
          )}
        </div>
      ))
    }
    <a href="/demo" class="btn btn--gold" style="margin-top:1rem;width:100%;justify-content:center;">Book a demo</a>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    transition: background 0.4s var(--ease), box-shadow 0.4s var(--ease),
      backdrop-filter 0.4s var(--ease), color 0.4s var(--ease);
    color: #fff;
  }
  .site-header[data-transparent] {
    background: transparent;
  }
  .site-header.scrolled {
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.06);
    color: var(--ink);
  }
  .header-inner {
    max-width: var(--maxw);
    margin-inline: auto;
    padding: 1.1rem var(--gutter);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    transition: padding 0.4s var(--ease);
  }
  .scrolled .header-inner {
    padding-block: 0.7rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.25rem;
    letter-spacing: -0.02em;
  }
  .brand-mark {
    width: auto;
    height: 28px;
    display: block;
  }

  .primary-nav {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-inline: auto;
  }
  .nav-item.has-menu {
    position: relative;
  }
  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.5rem 0.9rem;
    border-radius: 100px;
    font-size: 0.92rem;
    font-weight: 500;
    color: currentColor;
    opacity: 0.85;
    transition: opacity 0.25s, background 0.25s;
  }
  .nav-link:hover,
  .nav-link.active {
    opacity: 1;
  }
  .scrolled .nav-link:hover {
    background: rgba(0, 0, 0, 0.05);
  }
  .nav-link svg {
    opacity: 0.6;
    transition: transform 0.3s var(--ease);
  }
  .has-menu:hover .nav-link svg {
    transform: rotate(180deg);
  }

  .dropdown {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    padding-top: 0.7rem;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s var(--ease), transform 0.3s var(--ease);
  }
  .has-menu:hover .dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }
  .dropdown-inner {
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: saturate(180%) blur(24px);
    -webkit-backdrop-filter: saturate(180%) blur(24px);
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 0.5rem;
    min-width: 200px;
    box-shadow: var(--shadow-soft);
    display: flex;
    flex-direction: column;
  }
  .dropdown-link {
    padding: 0.6rem 0.9rem;
    border-radius: 12px;
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--ink);
    transition: background 0.2s, color 0.2s;
  }
  .dropdown-link:hover {
    background: var(--gold-soft);
    color: var(--gold);
  }

  .btn--sm {
    padding: 0.6rem 1.2rem;
    font-size: 0.88rem;
  }
  .site-header[data-transparent]:not(.scrolled) .btn--primary {
    background: #fff;
    color: var(--ink);
  }
  .site-header[data-transparent]:not(.scrolled) .btn--primary:hover {
    background: var(--gold);
    color: #fff;
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: 0;
    cursor: pointer;
    padding: 6px;
  }
  .menu-toggle span {
    width: 24px;
    height: 2px;
    background: currentColor;
    border-radius: 2px;
    transition: transform 0.3s var(--ease), opacity 0.3s;
  }
  :global(.menu-open) .menu-toggle span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  :global(.menu-open) .menu-toggle span:nth-child(2) {
    opacity: 0;
  }
  :global(.menu-open) .menu-toggle span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .mobile-menu {
    display: none;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1rem var(--gutter) 2rem;
    background: rgba(255, 255, 255, 0.97);
    backdrop-filter: blur(20px);
    border-top: 1px solid var(--line);
    max-height: calc(100vh - 70px);
    overflow-y: auto;
  }
  :global(.menu-open) .mobile-menu {
    display: flex;
  }
  .mobile-link {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--ink);
    padding: 0.6rem 0;
  }
  .mobile-sub {
    display: flex;
    flex-direction: column;
    padding-left: 1rem;
    margin-bottom: 0.5rem;
  }
  .mobile-sublink {
    color: var(--grey);
    padding: 0.35rem 0;
    font-size: 0.98rem;
  }

  @media (max-width: 980px) {
    .primary-nav,
    .header-actions {
      display: none;
    }
    .menu-toggle {
      display: flex;
    }
    :global(.menu-open) .site-header {
      background: rgba(255, 255, 255, 0.97);
      color: var(--ink);
    }
  }
</style>

<script>
  const header = document.getElementById("site-header");
  const toggle = document.getElementById("menu-toggle");

  const onScroll = () => {
    if (window.scrollY > 40) header?.classList.add("scrolled");
    else header?.classList.remove("scrolled");
  };
  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();

  toggle?.addEventListener("click", () => {
    const open = document.body.classList.toggle("menu-open");
    toggle.setAttribute("aria-expanded", String(open));
  });
</script>
