---
// Support + FAQ section. Copy for the four cards is taken verbatim from the live
// holoconnects.com support block. The FAQ answers below are a sensible starter
// set drawn from site facts (sizes, buy/rent/lease, sectors, 470+ projects in
// 30+ countries) — edit freely.
import { site } from "../data/site";
import { getLangFromUrl, t, type Lang } from "../i18n/ui";

interface Props {
  lang?: Lang;
}
const lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const tl = (v: { en: string; nl: string; de?: string }) => t(v, lang);

const waNumber = site.whatsapp.replace(/[^0-9]/g, "");
const waText = tl({
  en: "Hi Holoconnects, I have a question.",
  nl: "Hoi Holoconnects, ik heb een vraag.",
  de: "Hallo Holoconnects, ich habe eine Frage.",
});
const waHref = `https://wa.me/${waNumber}?text=${encodeURIComponent(waText)}`;
const phoneTel = `tel:${site.supportPhone.replace(/[^0-9+]/g, "")}`;

const copy = {
  eyebrow: { en: "Support", nl: "Support", de: "Support" },
  title: {
    en: "Questions? We are here to help.",
    nl: "Vragen? We helpen u graag.",
    de: "Fragen? Wir helfen Ihnen gerne.",
  },
  cardPhoneTitle: { en: "Personal contact", nl: "Persoonlijk contact", de: "Persönlicher Kontakt" },
  cardPhoneText: {
    en: `Call one of our support consultants on ${site.supportPhone}.`,
    nl: `Bel een van onze supportconsulenten op ${site.supportPhone}.`,
    de: `Rufen Sie einen unserer Support-Berater an unter ${site.supportPhone}.`,
  },
  cardMailTitle: { en: "Mail your question", nl: "Mail uw vraag", de: "Frage per E-Mail" },
  cardMailText: {
    en: `Mail your question to ${site.supportEmail}.`,
    nl: `Mail uw vraag naar ${site.supportEmail}.`,
    de: `Senden Sie Ihre Frage per E-Mail an ${site.supportEmail}.`,
  },
  cardChatTitle: { en: "Chat with us", nl: "Chat met ons", de: "Chatten Sie mit uns" },
  cardChatText: {
    en: "Ask your question easily via WhatsApp.",
    nl: "Stel uw vraag eenvoudig via WhatsApp.",
    de: "Stellen Sie Ihre Frage ganz einfach per WhatsApp.",
  },
  cardCenterTitle: { en: "Visit our support center", nl: "Bezoek ons supportcentrum", de: "Besuchen Sie unser Support-Center" },
  cardCenterText: {
    en: "Get instant answers to the most common questions.",
    nl: "Krijg direct antwoord op de meest gestelde vragen.",
    de: "Erhalten Sie sofort Antworten auf die häufigsten Fragen.",
  },
  faqTitle: { en: "Frequently asked questions", nl: "Veelgestelde vragen", de: "Häufig gestellte Fragen" },
} as const;

// FAQ copy — localized EN / NL / DE.
const faqs = [
  {
    q: { en: "What is a Holobox?", nl: "Wat is een Holobox?", de: "Was ist eine Holobox?" },
    a: {
      en: "A Holobox is a life-size holographic display that brings people, products and presenters to life in interactive 3D, so a real human presence can appear anywhere.",
      nl: "Een Holobox is een levensgroot holografisch display dat mensen, producten en presentatoren tot leven brengt in interactief 3D, zodat een echte menselijke aanwezigheid overal kan verschijnen.",
      de: "Eine Holobox ist ein lebensgroßes holografisches Display, das Menschen, Produkte und Präsentatoren in interaktivem 3D zum Leben erweckt, sodass eine echte menschliche Präsenz überall erscheinen kann.",
    },
  },
  {
    q: { en: "Which sizes are available?", nl: "Welke maten zijn beschikbaar?", de: "Welche Größen sind verfügbar?" },
    a: {
      en: "The range runs from a 22\" tabletop to the 86\" life-size flagship, with a 43\" model in between and the modular Hologrid for wall-size setups.",
      nl: "Het assortiment loopt van een 22\"-tafelmodel tot het 86\" levensgrote vlaggenschip, met een 43\"-model daartussen en de modulaire Hologrid voor wandopstellingen.",
      de: "Das Sortiment reicht vom 22\"-Tischmodell bis zum 86\" lebensgroßen Flaggschiff, mit einem 43\"-Modell dazwischen und dem modularen Hologrid für wandgroße Installationen.",
    },
  },
  {
    q: { en: "Can I buy, rent or lease a Holobox?", nl: "Kan ik een Holobox kopen, huren of leasen?", de: "Kann ich eine Holobox kaufen, mieten oder leasen?" },
    a: {
      en: "Yes. We offer purchase, rental and lease options. Book a demo and we will advise what fits your use case and budget, with real numbers.",
      nl: "Ja. We bieden koop-, huur- en leaseopties. Boek een demo en we adviseren wat past bij uw use case en budget, met concrete cijfers.",
      de: "Ja. Wir bieten Kauf-, Miet- und Leasingoptionen. Buchen Sie eine Demo und wir beraten Sie mit konkreten Zahlen, was zu Ihrem Anwendungsfall und Budget passt.",
    },
  },
  {
    q: { en: "How does the hologram work?", nl: "Hoe werkt het hologram?", de: "Wie funktioniert das Hologramm?" },
    a: {
      en: "A transparent display shows specially prepared content at human scale. Presenters can be streamed live or played from pre-recorded content, managed remotely through Holocontrol.",
      nl: "Een transparant display toont speciaal voorbereide content op menselijke schaal. Presentatoren kunnen live worden gestreamd of vanaf vooraf opgenomen content worden afgespeeld, op afstand beheerd via Holocontrol.",
      de: "Ein transparentes Display zeigt speziell aufbereitete Inhalte in menschlicher Größe. Präsentatoren können live gestreamt oder aus vorab aufgezeichneten Inhalten abgespielt und über Holocontrol aus der Ferne verwaltet werden.",
    },
  },
  {
    q: { en: "Which industries use Holoconnects?", nl: "Welke branches gebruiken Holoconnects?", de: "Welche Branchen nutzen Holoconnects?" },
    a: {
      en: "Hospitality, retail, telehealth, events, education and advertising, among others. Hospitality is our flagship use case with a 24/7 holographic concierge.",
      nl: "Onder meer hospitality, retail, telehealth, evenementen, onderwijs en adverteren. Hospitality is onze belangrijkste use case met een 24/7 holografische concierge.",
      de: "Unter anderem Hospitality, Einzelhandel, Telemedizin, Events, Bildung und Werbung. Hospitality ist unser wichtigster Anwendungsfall mit einem holografischen Concierge rund um die Uhr.",
    },
  },
  {
    q: { en: "Do you deliver and support internationally?", nl: "Leveren en ondersteunen jullie internationaal?", de: "Liefern und betreuen Sie international?" },
    a: {
      en: "Yes. We have completed 470+ projects in 30+ countries, with offices in the Netherlands and the United States and full ongoing support.",
      nl: "Ja. We hebben 470+ projecten voltooid in 30+ landen, met kantoren in Nederland en de Verenigde Staten en volledige doorlopende support.",
      de: "Ja. Wir haben über 470 Projekte in mehr als 30 Ländern realisiert, mit Standorten in den Niederlanden und den USA und umfassendem laufendem Support.",
    },
  },
];
---

<section class="section section--soft support" id="support">
  <div class="container">
    <div class="support-head" data-reveal>
      <p class="eyebrow">{tl(copy.eyebrow)}</p>
      <h2 class="section-title">{tl(copy.title)}</h2>
    </div>

    <div class="support-grid">
      <a class="support-card" href={phoneTel} data-tilt="4" data-reveal>
        <span class="support-ico" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M5 4h3l1.5 4-2 1.5a12 12 0 005 5l1.5-2 4 1.5v3a2 2 0 01-2 2A16 16 0 013 6a2 2 0 012-2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
        </span>
        <h3>{tl(copy.cardPhoneTitle)}</h3>
        <p>{tl(copy.cardPhoneText)}</p>
      </a>

      <a class="support-card" href={`mailto:${site.supportEmail}`} data-tilt="4" data-reveal style="--reveal-delay:80ms">
        <span class="support-ico" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M4 7l8 6 8-6" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
        </span>
        <h3>{tl(copy.cardMailTitle)}</h3>
        <p>{tl(copy.cardMailText)}</p>
      </a>

      <a class="support-card" href={waHref} target="_blank" rel="noopener noreferrer" data-tilt="4" data-reveal style="--reveal-delay:160ms">
        <span class="support-ico" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M12 3a9 9 0 00-7.7 13.6L3 21l4.5-1.2A9 9 0 1012 3z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M8.5 9c0 4 2.5 6.5 6.5 6.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
        </span>
        <h3>{tl(copy.cardChatTitle)}</h3>
        <p>{tl(copy.cardChatText)}</p>
      </a>

      <a class="support-card" href="#faq" data-tilt="4" data-reveal style="--reveal-delay:240ms">
        <span class="support-ico" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/><path d="M9.5 9.5a2.5 2.5 0 014.5 1.5c0 1.5-2 2-2 3.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><circle cx="12" cy="17" r="0.6" fill="currentColor"/></svg>
        </span>
        <h3>{tl(copy.cardCenterTitle)}</h3>
        <p>{tl(copy.cardCenterText)}</p>
      </a>
    </div>

    <div class="faq" id="faq">
      <h3 class="faq-title" data-reveal>{tl(copy.faqTitle)}</h3>
      <div class="faq-list">
        {
          faqs.map((f, i) => (
            <details class="faq-item" data-reveal style={`--reveal-delay:${(i % 3) * 70}ms`}>
              <summary>
                <span>{tl(f.q)}</span>
                <svg class="faq-chevron" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M4 7l5 5 5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </summary>
              <p>{tl(f.a)}</p>
            </details>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .support-head {
    max-width: 720px;
    margin: 0 auto clamp(2.5rem, 5vw, 3.5rem);
    text-align: center;
  }

  .support-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }
  .support-card {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1.7rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
    box-shadow: var(--shadow-card);
    transition: transform 0.4s var(--ease), border-color 0.4s var(--ease);
  }
  .support-card:hover { transform: translateY(-4px); border-color: var(--line-strong); }
  .support-ico {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: var(--gold-soft);
    color: var(--gold);
    margin-bottom: 0.4rem;
  }
  .support-card h3 { font-size: 1.15rem; }
  .support-card p { color: var(--grey); margin: 0; font-size: 0.95rem; line-height: 1.55; }

  .faq { max-width: 820px; margin-inline: auto; }
  .faq-title {
    text-align: center;
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: clamp(1.5rem, 3vw, 2.2rem);
  }
  .faq-list { display: flex; flex-direction: column; gap: 0.8rem; }
  .faq-item {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
    overflow: hidden;
  }
  .faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.2rem 1.5rem;
    cursor: pointer;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.08rem;
    color: var(--ink);
    list-style: none;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-chevron { flex: none; color: var(--grey); transition: transform 0.3s var(--ease); }
  .faq-item[open] .faq-chevron { transform: rotate(180deg); }
  .faq-item p {
    margin: 0;
    padding: 0 1.5rem 1.4rem;
    color: var(--grey);
    line-height: 1.65;
    max-width: 68ch;
  }

  @media (max-width: 900px) {
    .support-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 520px) {
    .support-grid { grid-template-columns: 1fr; }
  }
</style>
