---
import {
  getLangFromUrl,
  localizePath,
  useTranslations,
  type Lang,
} from "../i18n/ui";

interface Props {
  title?: string;
  text?: string;
  lang?: Lang;
}
const lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const tt = useTranslations(lang);
const { title = tt("ctaBand.title"), text = tt("ctaBand.text") } = Astro.props;
---

<section class="section section--dark cta">
  <div class="container cta-inner anim anim-up">
    <div class="cta-glow" aria-hidden="true"></div>
    <p class="eyebrow">{tt("ctaBand.eyebrow")}</p>
    <h2 class="section-title">{title}</h2>
    <p class="lead measure center">{text}</p>
    <div class="cta-actions">
      <a href={localizePath("/demo", lang)} class="magnetic btn btn--gold">{tt("cta.bookDemo")}</a>
      <a href={localizePath("/products/holobox", lang)} class="magnetic btn btn--ghost">{tt("cta.exploreHolobox")}</a>
    </div>
  </div>
</section>

<style>
  .cta {
    position: relative;
    overflow: hidden;
  }
  .cta-inner {
    position: relative;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }
  .cta-glow {
    position: absolute;
    top: -40%;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 800px;
    max-width: 120vw;
    background: radial-gradient(circle, rgba(200, 120, 0, 0.22), transparent 60%);
    pointer-events: none;
  }
  .cta-actions {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    flex-wrap: wrap;
    justify-content: center;
  }
</style>
