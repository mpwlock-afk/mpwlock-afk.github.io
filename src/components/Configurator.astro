---
// Interactive Holobox configurator (sits under the size-range on the homepage).
// Model x finish x view. The 86" has the full matrix (black/white x front/left/
// right, from the studio render set); the 22/43/75 currently only have a black
// front render, so their finish/view options degrade gracefully (disabled) until
// matching renders are supplied. New component — does not touch SizeRange.astro.
import { getLangFromUrl, t, localizePath, type Lang } from "../i18n/ui";

interface Props {
  lang?: Lang;
}
const lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const tl = (v: { en: string; nl: string; de?: string }) => t(v, lang);

const copy = {
  eyebrow: { en: "Configure", nl: "Configureer", de: "Konfigurieren" },
  titleA: { en: "Build your ", nl: "Stel uw ", de: "Stellen Sie Ihre " },
  titleB: { en: "Holobox.", nl: "Holobox samen.", de: "Holobox zusammen." },
  lead: {
    en: "Pick a size, a finish and an angle. See it your way.",
    nl: "Kies een maat, een afwerking en een hoek. Bekijk uw holografisch display zoals u wilt.",
    de: "Wählen Sie Größe, Finish und Blickwinkel. Sehen Sie Ihr Hologramm Display ganz nach Ihren Wünschen.",
  },
  labelModel: { en: "Model", nl: "Model", de: "Modell" },
  labelFinish: { en: "Finish", nl: "Afwerking", de: "Finish" },
  labelView: { en: "View", nl: "Weergave", de: "Ansicht" },
  ariaModel: { en: "Model", nl: "Model", de: "Modell" },
  ariaFinish: { en: "Finish", nl: "Afwerking", de: "Finish" },
  ariaView: { en: "View", nl: "Weergave", de: "Ansicht" },
  colorBlack: { en: "Midnight Black", nl: "Midnight Black", de: "Midnight Black" },
  colorWhite: { en: "Starlight White", nl: "Starlight White", de: "Starlight White" },
  viewLeft: { en: "Left", nl: "Links", de: "Links" },
  viewFront: { en: "Front", nl: "Voor", de: "Vorne" },
  viewRight: { en: "Right", nl: "Rechts", de: "Rechts" },
  cta: { en: "Book a demo", nl: "Boek een demo", de: "Demo buchen" },
} as const;

// Strings the client-side script needs (alt text + the "coming soon" note).
const cfgStrings = {
  black: tl(copy.colorBlack),
  white: tl(copy.colorWhite),
  views: { left: tl(copy.viewLeft), front: tl(copy.viewFront), right: tl(copy.viewRight) },
  altView: { en: "view", nl: "weergave", de: "Ansicht" }[lang],
  // {label} is replaced client-side (functions don't survive define:vars).
  comingSoon: {
    en: "White finish and side views for the {label} are coming soon.",
    nl: "Witte afwerking en zijaanzichten voor de {label} volgen binnenkort.",
    de: "Weißes Finish und Seitenansichten für die {label} folgen in Kürze.",
  }[lang],
};

// Clean transparent cut-outs, shown whole. The 86" has the full studio matrix
// (black/white x front/left/right). 75/43 have a black front only; the 22" Mini
// uses the white transparent cut-out rendered black via CSS filter (`recolor`)
// until a dedicated black render lands. Options degrade gracefully (disabled).
const models = [
  {
    id: "86", label: '86"', name: "Holobox",
    colors: {
      black: {
        front: "/images/config/holobox86-black-front.png",
        left: "/images/config/holobox86-black-left.png",
        right: "/images/config/holobox86-black-right.png",
      },
      white: {
        front: "/images/config/holobox86-white-front.png",
        left: "/images/config/holobox86-white-left.png",
        right: "/images/config/holobox86-white-right.png",
      },
    },
  },
  { id: "75", label: '75"', name: "The 75", colors: { black: { front: "/images/holobox-75-black.png" } } },
  { id: "43", label: '43"', name: "The 43", colors: { black: { front: "/images/holobox-43.png" } } },
  { id: "22", label: '22"', name: "Mini", recolor: true, colors: { black: { front: "/images/holobox-mini-white.png" } } },
];

const start = models[0].colors.black.front;
---

<section class="section configurator" id="configurator">
  <div class="container">
    <div class="cfg-head" data-reveal>
      <p class="eyebrow">{tl(copy.eyebrow)}</p>
      <h2 class="cfg-title">{tl(copy.titleA)}<span class="holo-text">{tl(copy.titleB)}</span></h2>
      <p class="cfg-lead">{tl(copy.lead)}</p>
    </div>

    <div class="cfg" data-cfg>
      <div class="cfg__stage">
        <div class="cfg__glow" aria-hidden="true"></div>
        <img
          class="cfg__img"
          data-cfg-img
          src={start}
          alt={`Holobox 86", ${cfgStrings.black}, ${cfgStrings.views.front}`}
          width="1200"
          height="1520"
        />
      </div>

      <div class="cfg__panel">
        <div class="cfg__group">
          <span class="cfg__label">{tl(copy.labelModel)}</span>
          <div class="cfg__opts" role="group" aria-label={tl(copy.ariaModel)}>
            {models.map((m) => (
              <button type="button" class="cfg__chip" data-model={m.id}>{m.label}</button>
            ))}
          </div>
        </div>

        <div class="cfg__group">
          <span class="cfg__label">{tl(copy.labelFinish)}</span>
          <div class="cfg__opts" role="group" aria-label={tl(copy.ariaFinish)}>
            <button type="button" class="cfg__chip" data-color="black"><span class="cfg__dot cfg__dot--black"></span>{tl(copy.colorBlack)}</button>
            <button type="button" class="cfg__chip" data-color="white"><span class="cfg__dot cfg__dot--white"></span>{tl(copy.colorWhite)}</button>
          </div>
        </div>

        <div class="cfg__group">
          <span class="cfg__label">{tl(copy.labelView)}</span>
          <div class="cfg__opts" role="group" aria-label={tl(copy.ariaView)}>
            <button type="button" class="cfg__chip" data-view="left">{tl(copy.viewLeft)}</button>
            <button type="button" class="cfg__chip" data-view="front">{tl(copy.viewFront)}</button>
            <button type="button" class="cfg__chip" data-view="right">{tl(copy.viewRight)}</button>
          </div>
        </div>

        <p class="cfg__note" data-cfg-note hidden></p>

        <a href={localizePath("/demo", lang)} class="magnetic btn btn--gold cfg__cta">{tl(copy.cta)}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .configurator { background: #f5f5f7; color: var(--ink); }
  .cfg-head { max-width: 640px; margin: 0 auto clamp(2rem, 4vw, 3rem); text-align: center; }
  .cfg-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
  }
  .cfg-lead { margin-top: 0.9rem; color: var(--grey); }

  .cfg {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(1.5rem, 4vw, 3.5rem);
    align-items: center;
    max-width: 1040px;
    margin-inline: auto;
  }
  /* No card/frame: the box render (transparent PNG with its own soft shadow)
     sits directly on the section background, in the same block as the panel. */
  .cfg__stage {
    position: relative;
    background: transparent;
    border: 0;
    height: clamp(360px, 50vh, 520px);
    display: grid;
    place-items: center;
    overflow: hidden;
  }
  .cfg__glow {
    position: absolute;
    inset: 8% 4% 4%;
    background: radial-gradient(60% 60% at 50% 45%, rgba(234, 153, 20, 0.10), transparent 70%);
    pointer-events: none;
  }
  .cfg__img {
    position: relative;
    /* Constrain by BOTH axes so the whole cabinet always fits the stage and is
       never cropped by overflow (percentage height resolved against the wrong
       block and overflowed). object-fit:contain keeps the aspect ratio. */
    max-height: 94%;
    max-width: 88%;
    width: auto;
    height: auto;
    object-fit: contain;
    opacity: 1;
    transition: opacity 0.25s ease, transform 0.55s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: opacity, transform;
  }

  .cfg__panel { display: flex; flex-direction: column; gap: 1.6rem; }
  .cfg__group { display: flex; flex-direction: column; gap: 0.7rem; }
  .cfg__label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--grey-soft, #8a8a92);
  }
  .cfg__opts { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .cfg__chip {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid var(--line-strong, #d7d7dc);
    background: #fff;
    color: var(--ink);
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.6rem 1rem;
    border-radius: 100px;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s, color 0.2s, opacity 0.2s;
  }
  .cfg__chip:hover { border-color: var(--gold); }
  .cfg__chip.is-active {
    background: var(--ink);
    color: #fff;
    border-color: var(--ink);
  }
  .cfg__chip.is-disabled,
  .cfg__chip:disabled {
    opacity: 0.32;
    cursor: not-allowed;
    border-style: dashed;
  }
  .cfg__chip.is-disabled:hover { border-color: var(--line-strong, #d7d7dc); }
  .cfg__dot { width: 12px; height: 12px; border-radius: 50%; }
  .cfg__dot--black { background: #111; }
  .cfg__dot--white { background: #fff; border: 1px solid #c7c7cd; }
  .cfg__note { font-size: 0.82rem; color: var(--grey); margin: 0; }
  .cfg__cta { align-self: flex-start; margin-top: 0.4rem; }

  @media (max-width: 820px) {
    .cfg { grid-template-columns: 1fr; }
    .cfg__stage { order: -1; height: clamp(320px, 44vh, 440px); }
    .cfg__cta { align-self: stretch; text-align: center; }
  }
</style>

<script define:vars={{ models, cfgStrings }}>
  function initConfigurator() {
    document.querySelectorAll("[data-cfg]").forEach((root) => {
      if (root.dataset.wired) return;
      root.dataset.wired = "1";

      const img = root.querySelector("[data-cfg-img]");
      const note = root.querySelector("[data-cfg-note]");
      const byId = Object.fromEntries(models.map((m) => [m.id, m]));
      const state = { model: "86", color: "black", view: "front" };
      const colorName = (c) => (c === "white" ? cfgStrings.white : cfgStrings.black);
      const viewName = (v) => cfgStrings.views[v] || v;

      function resolve() {
        const m = byId[state.model];
        const color = m.colors[state.color] ? state.color : Object.keys(m.colors)[0];
        const views = m.colors[color];
        const view = views[state.view] ? state.view : (views.front ? "front" : Object.keys(views)[0]);
        return { m, color, view, src: views[view] };
      }

      function render() {
        const { m, color, view, src } = resolve();
        state.color = color;
        state.view = view;

        // Cross-fade + subtle slide toward the chosen side.
        const shift = view === "left" ? "-6%" : view === "right" ? "6%" : "0%";
        img.style.opacity = "0";
        setTimeout(() => {
          const onload = () => { img.style.opacity = "1"; };
          img.addEventListener("load", onload, { once: true });
          img.src = src;
          img.alt = `${m.name} ${m.label}, ${colorName(color)}, ${viewName(view)} ${cfgStrings.altView}`;
          // White cut-out shown as the black finish via filter (22" Mini).
          img.style.filter = m.recolor && color === "black" ? "invert(1)" : "";
          img.style.transform = `translateX(${shift})`;
          if (img.complete) { img.removeEventListener("load", onload); img.style.opacity = "1"; }
        }, 160);

        // Active + availability states.
        root.querySelectorAll("[data-model]").forEach((b) => {
          const on = b.dataset.model === state.model;
          b.classList.toggle("is-active", on);
          b.setAttribute("aria-pressed", String(on));
        });
        root.querySelectorAll("[data-color]").forEach((b) => {
          const ok = !!m.colors[b.dataset.color];
          b.disabled = !ok;
          b.classList.toggle("is-disabled", !ok);
          const on = ok && b.dataset.color === state.color;
          b.classList.toggle("is-active", on);
          b.setAttribute("aria-pressed", String(on));
        });
        root.querySelectorAll("[data-view]").forEach((b) => {
          const ok = !!m.colors[color][b.dataset.view];
          b.disabled = !ok;
          b.classList.toggle("is-disabled", !ok);
          const on = ok && b.dataset.view === state.view;
          b.classList.toggle("is-active", on);
          b.setAttribute("aria-pressed", String(on));
        });

        const onlyBlackFront = !m.colors.white && !m.colors.black.left && !m.colors.black.right;
        if (onlyBlackFront) {
          note.hidden = false;
          note.textContent = cfgStrings.comingSoon.replace("{label}", m.label);
        } else {
          note.hidden = true;
        }
      }

      root.querySelectorAll("[data-model]").forEach((b) =>
        b.addEventListener("click", () => { state.model = b.dataset.model; render(); })
      );
      root.querySelectorAll("[data-color]").forEach((b) =>
        b.addEventListener("click", () => { if (!b.disabled) { state.color = b.dataset.color; render(); } })
      );
      root.querySelectorAll("[data-view]").forEach((b) =>
        b.addEventListener("click", () => { if (!b.disabled) { state.view = b.dataset.view; render(); } })
      );

      render();
    });
  }

  if (!window.__cfgInit) {
    window.__cfgInit = true;
    document.addEventListener("astro:page-load", initConfigurator);
  }
  initConfigurator();
</script>
