---
// Product detail | single source for both locales. Render via the thin route
// files src/pages/products/[slug].astro (en) and src/pages/nl/products/[slug].astro (nl).
// Both routes own their own getStaticPaths and pass `product` + `lang`.
import Base from "../../layouts/Base.astro";
import CtaSection from "../CtaSection.astro";
import { products, type Product } from "../../data/site";
import { t, localizePath, type Lang } from "../../i18n/ui";

interface Props {
  lang: Lang;
  product: Product;
}
const { lang, product } = Astro.props;
const others = products.filter((p) => p.slug !== product.slug).slice(0, 3);

// Page copy for all three locales (en / nl / de).
const copy = {
  metaTitle: {
    en: `${product.name} | Holographic Display | Holoconnects`,
    nl: `${product.name} | Holografisch display | Holoconnects`,
    de: `${product.name} | Hologramm Display | Holoconnects`,
  },
  metaDescription: {
    en: `${t(product.summary, "en")} Used in 30+ countries for hospitality, retail and events.`,
    nl: `${t(product.summary, "nl")} In meer dan 30 landen ingezet voor hospitality, retail en evenementen.`,
    de: `${t(product.summary, "de")} In über 30 Ländern für Hospitality, Retail und Events im Einsatz.`,
  },
  bookDemo: { en: "Book a demo", nl: "Boek een demo", de: "Demo anfragen" },
  viewCases: { en: "View cases", nl: "Bekijk cases", de: "Cases ansehen" },
  whyEyebrow: { en: "Why it works", nl: "Waarom het werkt", de: "Warum es überzeugt" },
  whyTitle: { en: "Designed for presence.", nl: "Ontworpen voor aanwezigheid.", de: "Gemacht für echte Präsenz." },
  specEyebrow: { en: "Technical details", nl: "Technische details", de: "Technische Details" },
  specTitle: { en: "Specifications.", nl: "Specificaties.", de: "Spezifikationen." },
  exploreEyebrow: { en: "Keep exploring", nl: "Blijf ontdekken", de: "Weiter entdecken" },
  exploreTitle: { en: "More of the range.", nl: "Meer uit het gamma.", de: "Mehr aus der Produktreihe." },
  faqEyebrow: { en: "FAQ", nl: "Veelgestelde vragen", de: "Häufige Fragen" },
  faqTitle: { en: "Questions, answered.", nl: "Antwoorden op uw vragen.", de: "Ihre Fragen, beantwortet." },
  ctaTitle: {
    en: `See the ${product.name} in action`,
    nl: `Zie de ${product.name} in actie`,
    de: `Erleben Sie das ${product.name} in Aktion`,
  },
  bcHome: { en: "Home", nl: "Home", de: "Startseite" },
  bcProducts: { en: "Products", nl: "Producten", de: "Produkte" },
  imgAlt: {
    en: (name: string) => `${name} holographic display by Holoconnects`,
    nl: (name: string) => `${name} hologram display van Holoconnects`,
    de: (name: string) => `${name} Hologramm Display von Holoconnects`,
  },
} as const;

const tl = (v: { en: string; nl: string; de?: string }) => t(v, lang);

const site = Astro.site ?? new URL("https://www.holoconnects.com");
const productUrl = new URL(localizePath(`/products/${product.slug}`, lang), site).href;
const productLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: `${product.name} Holographic Display`,
  description: t(product.summary, lang),
  image: new URL(product.image, site).href,
  brand: { "@type": "Brand", name: "Holoconnects" },
  manufacturer: { "@type": "Organization", name: "Holoconnects" },
  url: productUrl,
  category: "Holographic display",
};
const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: tl(copy.bcHome), item: new URL(localizePath("/", lang), site).href },
    { "@type": "ListItem", position: 2, name: tl(copy.bcProducts), item: new URL(localizePath("/products", lang), site).href },
    { "@type": "ListItem", position: 3, name: product.name, item: productUrl },
  ],
};
const faqLd =
  product.faqs && product.faqs.length
    ? {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: product.faqs.map((f) => ({
          "@type": "Question",
          name: t(f.q, lang),
          acceptedAnswer: { "@type": "Answer", text: t(f.a, lang) },
        })),
      }
    : null;
const jsonLd = faqLd ? [productLd, breadcrumbLd, faqLd] : [productLd, breadcrumbLd];
---

<Base
  lang={lang}
  title={tl(copy.metaTitle)}
  description={tl(copy.metaDescription)}
  image={product.image}
  ogType="product"
  jsonLd={jsonLd}
>
  <section class="prod-hero section--dark">
    <div class="container prod-hero-grid">
      <div class="prod-hero-text">
        <p class="eyebrow anim anim-up">{product.name}</p>
        <h1 class="display anim anim-up" style="--d:80ms"><span class="holo-text">{t(product.tagline, lang)}</span></h1>
        <p class="lead anim anim-up" style="--d:160ms">{t(product.summary, lang)}</p>
        <div class="prod-hero-actions anim anim-up" style="--d:240ms">
          <a href={localizePath("/contact", lang)} class="magnetic btn btn--gold">{tl(copy.bookDemo)}</a>
          <a href={localizePath("/cases", lang)} class="magnetic btn btn--ghost">{tl(copy.viewCases)}</a>
        </div>
      </div>
      <div class="prod-hero-media anim anim-scale" style="--d:120ms">
        <div class="prod-glow" aria-hidden="true"></div>
        <img src={product.image} alt={copy.imgAlt[lang](product.name)} data-parallax="0.06" />
      </div>
    </div>
  </section>

  {
    product.features && (
      <section class="section">
        <div class="container">
          <div class="block-head" data-reveal>
            <p class="eyebrow">{tl(copy.whyEyebrow)}</p>
            <h2 class="section-title">{tl(copy.whyTitle)}</h2>
          </div>
          <div class="grid cols-2 feat-grid">
            {product.features.map((f, i) => (
              <div class="feat" data-tilt="4" data-reveal style={`--reveal-delay:${(i % 2) * 90}ms`}>
                <span class="feat-num">{String(i + 1).padStart(2, "0")}</span>
                <div>
                  <h3>{t(f.title, lang)}</h3>
                  <p class="text-muted">{t(f.body, lang)}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  {
    product.specs && (
      <section class="section section--soft">
        <div class="container">
          <div class="block-head" data-reveal>
            <p class="eyebrow">{tl(copy.specEyebrow)}</p>
            <h2 class="section-title">{tl(copy.specTitle)}</h2>
          </div>
          <div class="spec-grid" data-reveal>
            {product.specs.map((s) => (
              <div class="spec">
                <span class="spec-label">{t(s.label, lang)}</span>
                <span class="spec-value">{t(s.value, lang)}</span>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <section class="section">
    <div class="container">
      <div class="block-head" data-reveal>
        <p class="eyebrow">{tl(copy.exploreEyebrow)}</p>
        <h2 class="section-title">{tl(copy.exploreTitle)}</h2>
      </div>
      <div class="grid cols-3">
        {
          others.map((p, i) => (
            <a href={localizePath(`/products/${p.slug}`, lang)} class="mini-card" data-tilt="6" data-reveal style={`--reveal-delay:${i * 80}ms`}>
              <div class="mini-media"><img src={p.image} alt={copy.imgAlt[lang](p.name)} loading="lazy" /></div>
              <div class="mini-body">
                <h3>{p.name}</h3>
                <p class="text-muted">{t(p.tagline, lang)}</p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  {
    product.faqs && (
      <section class="section section--soft">
        <div class="container">
          <div class="block-head" data-reveal>
            <p class="eyebrow">{tl(copy.faqEyebrow)}</p>
            <h2 class="section-title">{tl(copy.faqTitle)}</h2>
          </div>
          <div class="faq-list" data-reveal>
            {product.faqs.map((f) => (
              <details class="faq-item">
                <summary>{t(f.q, lang)}</summary>
                <p>{t(f.a, lang)}</p>
              </details>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <CtaSection lang={lang} title={tl(copy.ctaTitle)} />
</Base>

<style>
  .prod-hero {
    padding-top: clamp(8rem, 14vw, 12rem);
    padding-bottom: clamp(4rem, 8vw, 7rem);
    overflow: hidden;
  }
  .prod-hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .prod-hero-text .lead {
    margin: 1.4rem 0 2rem;
    max-width: 46ch;
  }
  .prod-hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .prod-hero-media {
    position: relative;
    aspect-ratio: 1;
    display: grid;
    place-items: center;
  }
  .prod-glow {
    position: absolute;
    inset: 10%;
    background: radial-gradient(circle, rgba(200, 120, 0, 0.28), transparent 65%);
    filter: blur(10px);
  }
  .prod-hero-media img {
    position: relative;
    max-height: 520px;
    width: auto;
    object-fit: contain;
    filter: drop-shadow(0 40px 70px rgba(0, 0, 0, 0.55));
  }
  @media (max-width: 820px) {
    .prod-hero-grid { grid-template-columns: 1fr; }
    .prod-hero-media { order: -1; }
    .prod-hero-media img { max-height: 360px; }
  }

  .block-head { max-width: 760px; margin-bottom: clamp(2.5rem, 5vw, 4rem); }

  .feat {
    display: flex;
    gap: 1.25rem;
    padding: 1.5rem;
    border-radius: var(--radius);
    border: 1px solid var(--line);
    transition: border-color 0.4s, transform 0.4s;
  }
  .feat:hover { border-color: var(--line-strong); transform: translateY(-3px); }
  .feat-num {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--gold);
    font-size: 1.1rem;
  }
  .feat h3 { font-size: 1.25rem; margin-bottom: 0.4rem; }

  .spec-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .spec {
    background: var(--surface);
    padding: 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .spec-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--grey-soft);
  }
  .spec-value {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--ink);
  }
  @media (max-width: 760px) {
    .spec-grid { grid-template-columns: 1fr 1fr; }
  }

  .mini-card {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--surface);
    box-shadow: var(--shadow-card);
    transition: transform 0.4s var(--ease);
  }
  .mini-card:hover { transform: translateY(-5px); }
  .mini-media {
    aspect-ratio: 4 / 3;
    background: radial-gradient(circle at 50% 40%, #1a1a1d, #0a0a0a);
    display: grid;
    place-items: center;
  }
  .mini-media img { width: 100%; height: 100%; object-fit: contain; padding: 1.5rem; }
  .mini-body { padding: 1.4rem; }
  .mini-body h3 { font-size: 1.3rem; margin-bottom: 0.3rem; }

  .faq-list {
    max-width: 820px;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .faq-item {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
    padding: 0 1.4rem;
    transition: border-color 0.4s;
  }
  .faq-item:hover { border-color: var(--line-strong); }
  .faq-item[open] { border-color: var(--line-strong); }
  .faq-item summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 0;
    font-family: var(--font-display);
    font-size: 1.12rem;
    font-weight: 600;
    color: var(--ink);
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after {
    content: "+";
    flex-shrink: 0;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.4rem;
    line-height: 1;
    color: var(--gold);
    transition: transform 0.3s var(--ease);
  }
  .faq-item[open] summary::after { transform: rotate(45deg); }
  .faq-item p {
    margin: 0;
    padding: 0 0 1.25rem;
    max-width: 68ch;
    line-height: 1.7;
    color: var(--text-muted);
  }
</style>
