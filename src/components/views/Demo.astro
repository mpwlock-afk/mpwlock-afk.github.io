---
// Demo page | single source for both locales. Render via the thin route files
// src/pages/demo.astro (en) and src/pages/nl/demo.astro (nl).
import Base from "../../layouts/Base.astro";
import { site } from "../../data/site";
import { t, type Lang } from "../../i18n/ui";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const calendly =
  "https://calendly.com/mpw-lock/30min?hide_gdpr_banner=1&background_color=0a0a0a&text_color=ffffff&primary_color=ea9914";

// Page copy. Localized in en / nl / de.
const copy = {
  meta: {
    title: {
      en: "Book a demo | Holoconnects",
      nl: "Demo boeken | Holoconnects",
      de: "Hologramm Demo buchen | Holoconnects",
    },
    description: {
      en: "Schedule a live 30-minute Holobox demo directly in our calendar.",
      nl: "Plan direct in onze agenda een live Holobox-demo van 30 minuten. Vraag uw hologram demo aan.",
      de: "Buchen Sie direkt in unserem Kalender eine 30-minütige Live-Demo der Holobox. Erleben Sie das Hologramm aus erster Hand.",
    },
  },
  eyebrow: { en: "Book a demo", nl: "Demo boeken", de: "Demo buchen" },
  h1a: { en: "See it ", nl: "Zie het ", de: "Erleben Sie es " },
  h1b: { en: "life-size.", nl: "levensgroot.", de: "lebensgroß." },
  lead: {
    en: "Pick a slot. 30 minutes with our team, live on a Holobox.",
    nl: "Kies een tijdslot. 30 minuten met ons team, live op een Holobox.",
    de: "Wählen Sie einen Termin. 30 Minuten mit unserem Team, live auf einer Holobox.",
  },
  calTitle: {
    en: "Schedule a Holoconnects demo",
    nl: "Plan een Holoconnects-demo",
    de: "Holoconnects-Demo buchen",
  },
  points: [
    {
      h: { en: "Live, not a video", nl: "Live, geen video", de: "Live, kein Video" },
      p: {
        en: "We broadcast in real time, so you experience the presence first-hand.",
        nl: "We zenden in realtime uit, zodat u de aanwezigheid zelf ervaart.",
        de: "Wir übertragen in Echtzeit, sodass Sie die Präsenz aus erster Hand erleben.",
      },
    },
    {
      h: { en: "Tailored to your sector", nl: "Afgestemd op uw sector", de: "Auf Ihre Branche zugeschnitten" },
      p: {
        en: "Hospitality, retail, events or telehealth, we demo your use case.",
        nl: "Hospitality, retail, evenementen of telehealth: we demonstreren uw use case.",
        de: "Hospitality, Retail, Events oder Telehealth: Wir zeigen Ihren Anwendungsfall.",
      },
    },
    {
      h: { en: "Honest advice", nl: "Eerlijk advies", de: "Ehrliche Beratung" },
      p: {
        en: "Buy, rent or lease. We'll tell you what fits, with real numbers.",
        nl: "Kopen, huren of leasen. We vertellen u eerlijk wat bij u past, met concrete cijfers.",
        de: "Kauf, Miete oder Leasing. Wir sagen Ihnen, was passt, mit konkreten Zahlen.",
      },
    },
  ],
  altLabel: {
    en: "Prefer email or phone?",
    nl: "Liever e-mail of telefoon?",
    de: "Lieber per E-Mail oder Telefon?",
  },
} as const;

const tl = (v: { en: string; nl: string; de?: string }) => t(v, lang);
---

<Base lang={lang} title={tl(copy.meta.title)} description={tl(copy.meta.description)}>
  <section class="page-hero section--dark">
    <div class="container">
      <p class="eyebrow anim anim-up">{tl(copy.eyebrow)}</p>
      <h1 class="display anim anim-up" style="--d:80ms">{tl(copy.h1a)}<span class="holo-text">{tl(copy.h1b)}</span></h1>
      <p class="lead measure anim anim-up" style="--d:160ms">
        {tl(copy.lead)}
      </p>
    </div>
  </section>

  <section class="section section--dark demo-sec">
    <div class="container demo-grid">
      <div class="demo-cal anim anim-scale" style="--d:120ms">
        <iframe
          src={calendly}
          title={tl(copy.calTitle)}
          loading="lazy"
          data-lenis-prevent
        ></iframe>
      </div>
      <aside class="demo-side">
        {copy.points.map((pt, i) => (
          <div class="demo-point anim anim-up" style={`--d:${200 + i * 80}ms`}>
            <span class="demo-num holo-text">{String(i + 1).padStart(2, "0")}</span>
            <div>
              <h3>{tl(pt.h)}</h3>
              <p>{tl(pt.p)}</p>
            </div>
          </div>
        ))}
        <div class="demo-alt anim anim-up" style="--d:440ms">
          <p>{tl(copy.altLabel)}</p>
          <a href={`mailto:${site.email}`}>{site.email}</a>
          <a href={`tel:${site.phoneHref}`}>{site.phone}</a>
        </div>
      </aside>
    </div>
  </section>
</Base>

<style>
  .page-hero {
    padding-top: clamp(8rem, 14vw, 12rem);
    padding-bottom: clamp(2rem, 4vw, 3rem);
  }
  .page-hero .lead { margin-top: 1.4rem; }

  .demo-sec { padding-top: 0; }
  .demo-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: start;
  }
  .demo-cal {
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: #0a0a0a;
    box-shadow: 0 40px 90px -40px rgba(200, 120, 0, 0.25);
  }
  .demo-cal iframe {
    display: block;
    width: 100%;
    height: 760px;
    border: 0;
  }
  .demo-side {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
    position: sticky;
    top: 7rem;
  }
  .demo-point {
    display: flex;
    gap: 1.1rem;
    padding: 1.4rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.03);
  }
  .demo-num {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: 0.08em;
  }
  .demo-point h3 {
    color: #fff;
    font-size: 1.15rem;
    margin-bottom: 0.35rem;
  }
  .demo-point p {
    color: #a6a6ae;
    margin: 0;
    font-size: 0.95rem;
  }
  .demo-alt {
    padding: 1.4rem;
    border-radius: var(--radius);
    background: var(--grad-gold);
    color: #0a0a0a;
  }
  .demo-alt p {
    font-weight: 700;
    margin-bottom: 0.4rem;
  }
  .demo-alt a {
    display: block;
    font-weight: 600;
    padding: 0.15rem 0;
  }
  .demo-alt a:hover { text-decoration: underline; }

  @media (max-width: 860px) {
    .demo-grid { grid-template-columns: 1fr; }
    .demo-side { position: static; }
    .demo-cal iframe { height: 640px; }
  }
</style>
