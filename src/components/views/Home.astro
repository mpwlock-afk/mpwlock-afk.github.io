---
// Homepage body | single source for both locales. Render via the thin route files
// src/pages/index.astro (en) and src/pages/nl/index.astro (nl).
import Base from "../../layouts/Base.astro";
import CtaSection from "../CtaSection.astro";
import { products, sectors, stats, testimonials } from "../../data/site";
import SizeRange from "../SizeRange.astro";
import Configurator from "../Configurator.astro";
import Support from "../Support.astro";
import { t, localizePath, type Lang } from "../../i18n/ui";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const tl = (v: { en: string; nl: string; de?: string }) => t(v, lang);

// Ecosystem "Scroll the hologram range" cards: full size lineup + Hologrid, each
// with a short story. `recolor` shows the white 22" cut-out as the black finish.
const rangeCards = [
  {
    img: "/images/holobox-black.png", recolor: false, name: 'Holobox 86"', href: "/products/holobox",
    story: {
      en: "The life-size flagship. An 86\" transparent LCD that brings people and products to true human scale.",
      nl: "Het levensgrote vlaggenschip. Een 86\"-transparant LCD dat mensen en producten op ware grootte tot leven brengt.",
      de: "Das lebensgroße Flaggschiff. Ein 86\" transparentes LCD, das Menschen und Produkte in echter Lebensgröße zeigt.",
    },
  },
  {
    img: "/images/holobox-75-black.png", recolor: false, name: 'Holobox 75"', href: "/products/holobox",
    story: {
      en: "The same striking presence in a slightly smaller cabinet, ideal for lobbies and receptions.",
      nl: "Dezelfde indrukwekkende aanwezigheid in een iets kleinere behuizing, ideaal voor lobby's en recepties.",
      de: "Dieselbe eindrucksvolle Präsenz in einem etwas kleineren Gehäuse, ideal für Lobbys und Empfangsbereiche.",
    },
  },
  {
    img: "/images/holobox-43.png", recolor: false, name: "The 43", href: "/products/the-43",
    story: {
      en: "Compact 43\" holographic impact for booths, counters and tighter retail spaces.",
      nl: "Compacte 43\"-holografische impact voor stands, toonbanken en krappere retailruimtes.",
      de: "Kompakte 43\"-holografische Wirkung für Messestände, Theken und kleinere Retailflächen.",
    },
  },
  {
    img: "/images/holobox-mini-white.png", recolor: true, name: 'Holobox Mini 22"', href: "/products/holobox-mini",
    story: {
      en: "The desktop Mini. Product reveals and showcases with the same holographic depth on any counter.",
      nl: "De desktop Mini. Productonthullingen en showcases met dezelfde holografische diepte op elke toonbank.",
      de: "Der Desktop-Mini. Produktpräsentationen mit derselben holografischen Tiefe auf jeder Theke.",
    },
  },
  {
    img: "/images/holobox-hologrid.png", recolor: false, name: "Hologrid", href: "/products/hologrid",
    story: {
      en: "Up to five Holobox units combined into one modular holographic wall for events and flagship spaces.",
      nl: "Tot vijf Holobox-units samengevoegd tot één modulaire holografische wand voor evenementen en flagship-ruimtes.",
      de: "Bis zu fünf Holobox-Einheiten zu einer modularen holografischen Wand für Events und Flagship-Räume.",
    },
  },
];

// Brands Holoconnects has worked with, shown as a white monochrome "Trusted by"
// wall. A logo file in /images/logos/ renders as an <img> forced to white by CSS;
// a brand without a logo yet falls back to its name in white text. Drop official
// logos (svg/png, any colour, transparent background) in to complete the set.
// Brand names | kept as-is (not translated).
const clients = [
  { name: "Best Western", logo: "" },
  { name: "UNICEF", logo: "" },
  { name: "Deloitte", logo: "" },
  { name: "Vodafone", logo: "/images/logos/vodafone.svg" },
  { name: "BMW", logo: "/images/logos/bmw.svg" },
  { name: "ING", logo: "" },
  { name: "Visit Britain", logo: "" },
];

// Page copy. Localized as { en, nl, de }.
const copy = {
  meta: {
    title: {
      en: "Holoconnects | Life-Size Interactive Holograms | Europe's Leading Hologram Company",
      nl: "Holoconnects | Levensgroot hologram & interactief holografisch display | Europa's hologramspecialist",
      de: "Holoconnects | Lebensgroße interaktive Hologramme | Führender Anbieter für Hologramm Displays in Europa",
    },
    description: {
      en: "Interactive life-size holographic displays for hospitality, retail, healthcare and events. 470+ projects in 30+ countries. Book a demo.",
      nl: "Interactieve, levensgrote holografische displays voor hospitality, retail, zorg en events. 470+ projecten in 30+ landen. Boek een demo.",
      de: "Interaktive, lebensgroße holografische Displays für Hospitality, Retail, Healthcare und Events. 470+ Projekte in 30+ Ländern. Demo buchen.",
    },
  },
  heroTag: {
    en: "Innovation with a human touch",
    nl: "Innovatie met een menselijke touch",
    de: "Innovation mit menschlicher Note",
  },
  heroTitleStart: { en: "Real people,", nl: "Echte mensen,", de: "Echte Menschen," },
  heroRotator: [
    { en: "real connections.", nl: "echte connecties.", de: "echte Verbindungen." },
    { en: "24/7 hospitality.", nl: "24/7 hospitality.", de: "24/7 Hospitality." },
    { en: "life-size presence.", nl: "levensgrote aanwezigheid.", de: "lebensgroße Präsenz." },
    { en: "global reach.", nl: "wereldwijd bereik.", de: "globale Reichweite." },
  ],
  heroSub: {
    en: "Life-size, interactive holograms that bring a human presence anywhere.",
    nl: "Levensgrote, interactieve hologrammen die overal een menselijke aanwezigheid creëren.",
    de: "Lebensgroße, interaktive Hologramme, die überall eine menschliche Präsenz schaffen.",
  },
  heroBookDemo: { en: "Book a demo", nl: "Boek een demo", de: "Demo buchen" },
  heroDiscover: { en: "Discover the Holobox", nl: "Ontdek de Holobox", de: "Holobox entdecken" },
  heroRating: {
    en: "★ 9.5/10 · 346 reviews",
    nl: "★ 9,5/10 · 346 reviews",
    de: "★ 9,5/10 · 346 Bewertungen",
  },
  heroScrollCue: { en: "Scroll to explore", nl: "Scroll om te ontdekken", de: "Scrollen zum Entdecken" },

  trustedLabel: {
    en: "Trusted by leading organisations worldwide",
    nl: "Vertrouwd door toonaangevende organisaties wereldwijd",
    de: "Vertraut von führenden Organisationen weltweit",
  },

  hospoEyebrow: { en: "Flagship · Hospitality", nl: "Flagship · Hospitality", de: "Flagship · Hospitality" },
  hospoTitleA: { en: "The 24/7 holographic", nl: "De 24/7 holografische", de: "Der holografische 24/7-" },
  hospoTitleB: { en: "concierge.", nl: "concierge.", de: "Concierge." },
  hospoLead: {
    en: "One host. Every lobby. A welcome that never sleeps.",
    nl: "Eén host. Elke lobby. Een welkom dat nooit slaapt.",
    de: "Ein Gastgeber. Jede Lobby. Ein Empfang, der niemals schläft.",
  },
  hospoCta: { en: "Explore hospitality", nl: "Ontdek hospitality", de: "Hospitality entdecken" },
  hospoStat1: { en: "Front-desk costs", nl: "Receptiekosten", de: "Empfangskosten" },
  hospoStat2: { en: "Guest presence", nl: "Gastaanwezigheid", de: "Gästepräsenz" },
  hospoStat3: { en: "Hotels live", nl: "Hotels live", de: "Hotels live" },

  hpinEyebrow: { en: "The ecosystem", nl: "Het ecosysteem", de: "Das Ökosystem" },
  hpinTitleA: { en: "Scroll the", nl: "Scroll door het", de: "Scrollen Sie durch das" },
  hpinTitleB: { en: "hologram range.", nl: "hologramassortiment.", de: "Hologramm-Sortiment." },
  hpinIntro: {
    en: 'One platform powers every display, from a life-size 86" Holobox to a desktop Mini and modular walls.',
    nl: 'Eén platform stuurt elk display aan, van een levensgrote 86" Holobox tot een desktop Mini en modulaire wanden.',
    de: 'Eine Plattform steuert jedes Display, vom lebensgroßen 86" Holobox bis zum Desktop-Mini und modularen Wänden.',
  },
  hpinHint: { en: "Keep scrolling →", nl: "Blijf scrollen →", de: "Weiter scrollen →" },
  cardExplore: { en: "Explore", nl: "Ontdek", de: "Entdecken" },

  valuesEyebrow: { en: "Why Holoconnects", nl: "Waarom Holoconnects", de: "Warum Holoconnects" },
  valuesLine1: { en: "Technology that brings", nl: "Technologie die mensen", de: "Technologie, die Menschen" },
  valuesLine2a: { en: "people ", nl: "dichter ", de: "näher " },
  valuesLine2b: { en: "closer", nl: "bij elkaar", de: "zusammen" },
  valuesLine2c: { en: ", not", nl: " brengt, geen", de: "bringt, keine" },
  valuesLine3: { en: "screens between them.", nl: "schermen ertussen.", de: "Bildschirme dazwischen." },
  value1Title: { en: "A human touch", nl: "Een menselijke touch", de: "Eine menschliche Note" },
  value1Body: {
    en: "Technology that deepens human connection instead of replacing it.",
    nl: "Technologie die menselijke verbinding verdiept in plaats van vervangt.",
    de: "Technologie, die menschliche Verbindung vertieft, statt sie zu ersetzen.",
  },
  value2Title: { en: "Real presence", nl: "Echte aanwezigheid", de: "Echte Präsenz" },
  value2Body: {
    en: "A genuinely personal presence in any virtual space.",
    nl: "Een echt persoonlijke aanwezigheid in elke virtuele ruimte.",
    de: "Eine wirklich persönliche Präsenz in jedem virtuellen Raum.",
  },
  value3Title: { en: "Sustainable reach", nl: "Duurzaam bereik", de: "Nachhaltige Reichweite" },
  value3Body: {
    en: "Broader reach, lower footprint, inclusive by design.",
    nl: "Breder bereik, kleinere voetafdruk, inclusief van opzet.",
    de: "Größere Reichweite, kleinerer Fußabdruck, von Grund auf inklusiv.",
  },

  sectorsTitleA: { en: "Built for the moments", nl: "Gebouwd voor de momenten", de: "Gemacht für die Momente," },
  sectorsTitleB: { en: "that matter.", nl: "die ertoe doen.", de: "die zählen." },
  sectorsLead: {
    en: "From guest experiences in hospitality to virtual care in telehealth, lifelike presence where it counts.",
    nl: "Van gastervaringen in hospitality tot virtuele zorg in telehealth: levensechte aanwezigheid waar het telt.",
    de: "Von Gästeerlebnissen in der Hospitality bis zur virtuellen Betreuung im Telehealth: lebensechte Präsenz, wo sie zählt.",
  },

  quoteEyebrow: { en: "In their words", nl: "In hun woorden", de: "In ihren Worten" },
  quoteTitleA: { en: "Trusted by teams", nl: "Vertrouwd door teams", de: "Vertraut von Teams" },
  quoteTitleB: { en: "around the world.", nl: "over de hele wereld.", de: "auf der ganzen Welt." },
} as const;
---

<Base
  lang={lang}
  title={tl(copy.meta.title)}
  description={tl(copy.meta.description)}
>
  <!-- ============ HERO ============ -->
  <section class="hero">
    <canvas id="holo-canvas" class="hero-canvas" aria-hidden="true"></canvas>
    <div class="hero-mesh" aria-hidden="true"></div>
    <div class="hero-scan" aria-hidden="true"></div>

    <div class="container hero-content" data-depth>
      <span class="hero-tag">
        <span class="hero-tag-dot"></span>{tl(copy.heroTag)}
      </span>
      <h1 class="hero-title">
        <span class="kinetic" data-split>{tl(copy.heroTitleStart)}</span>
        <span class="hero-rotator">
          {copy.heroRotator.map((w) => (
            <span class="holo-text">{tl(w)}</span>
          ))}
        </span>
      </h1>
      <p class="hero-sub anim anim-up" style="--d:500ms">
        {tl(copy.heroSub)}
      </p>
      <div class="hero-actions anim anim-up" style="--d:640ms">
        <a href={localizePath("/demo", lang)} class="magnetic btn btn--gold">{tl(copy.heroBookDemo)}</a>
        <a href={localizePath("/products/holobox", lang)} class="magnetic btn btn--ghost-light">{tl(copy.heroDiscover)}</a>
      </div>
    </div>

    <div class="hero-foot">
      <span class="hero-foot-rating">{tl(copy.heroRating)}</span>
      <span class="hero-scrollcue">{tl(copy.heroScrollCue)}<span class="hero-scrollcue-line"></span></span>
    </div>
  </section>

  <!-- ============ TRUSTED BY ============ -->
  <section class="trusted">
    <div class="container">
      <p class="trusted__label anim anim-up">{tl(copy.trustedLabel)}</p>
      <div class="trusted__row">
        {
          clients.map((c, i) => (
            <div class="trusted__item anim anim-up" style={`--d:${i * 60}ms`}>
              {c.logo ? (
                <img
                  class="trusted__logo"
                  src={c.logo}
                  alt={`${c.name} logo`}
                  loading="lazy"
                  width="120"
                  height="34"
                />
              ) : (
                <span class="trusted__logo">{c.name}</span>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ STATS ============ -->
  <section class="section stats-sec">
    <div class="container">
      <div class="stats-row">
        {
          stats.map((s) => (
            <div class="stat-cell anim anim-up">
              <span class="stat-num" data-count={s.value}>{s.value}</span>
              <span class="stat-cap">{tl(s.label)}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ HOSPITALITY SHOWCASE ============ -->
  <section class="hospo">
    <div class="hospo__media">
      <img src="/images/sector-hospitality.jpg" alt="Holographic concierge in hospitality" data-parallax="0.12" />
    </div>
    <div class="hospo__veil"></div>
    <div class="container hospo__content">
      <span class="eyebrow anim anim-up">{tl(copy.hospoEyebrow)}</span>
      <h2 class="hospo__title anim anim-up" style="--d:80ms">
        {tl(copy.hospoTitleA)}<br /><span class="holo-text">{tl(copy.hospoTitleB)}</span>
      </h2>
      <p class="hospo__lead anim anim-up" style="--d:160ms">
        {tl(copy.hospoLead)}
      </p>
      <a href={localizePath("/sectors", lang)} class="magnetic btn btn--gold anim anim-up" style="--d:240ms">{tl(copy.hospoCta)}</a>
    </div>
    <div class="hospo__stats">
      <div class="hospo__stat anim anim-up"><span>-40%</span><small>{tl(copy.hospoStat1)}</small></div>
      <div class="hospo__stat anim anim-up" style="--d:90ms"><span>24/7</span><small>{tl(copy.hospoStat2)}</small></div>
      <div class="hospo__stat anim anim-up" style="--d:180ms"><span>30+</span><small>{tl(copy.hospoStat3)}</small></div>
    </div>
  </section>

  <!-- ============ SIZE RANGE ============ -->
  <SizeRange lang={lang} />

  <!-- ============ CONFIGURATOR ============ -->
  <Configurator lang={lang} />

  <!-- ============ PINNED HORIZONTAL PRODUCTS ============ -->
  <section class="hpin section--dark" data-hscroll>
    <div class="hpin__sticky">
      <div class="container hpin__head">
        <span class="eyebrow">{tl(copy.hpinEyebrow)}</span>
        <h2 class="hpin__title">{tl(copy.hpinTitleA)}<br /><span class="holo-text">{tl(copy.hpinTitleB)}</span></h2>
      </div>
      <div class="hpin__track">
        <div class="hpin__intro">
          <p class="lead">{tl(copy.hpinIntro)}</p>
          <span class="hpin__hint">{tl(copy.hpinHint)}</span>
        </div>
        {
          rangeCards.map((p, i) => (
            <a href={localizePath(p.href, lang)} class="hcard hoverable" data-tilt="5">
              <span class="hcard__index">{String(i + 1).padStart(2, "0")}</span>
              <div class="hcard__media">
                <div class="hcard__glow"></div>
                <img src={p.img} class={p.recolor ? "is-recolor-black" : ""} alt={`${p.name} holographic display by Holoconnects`} loading="lazy" />
              </div>
              <div class="hcard__body">
                <h3>{p.name}</h3>
                <p>{tl(p.story)}</p>
                <span class="arrow-link">{tl(copy.cardExplore)}
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h9M8 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ VALUES ============ -->
  <section class="section values-sec">
    <div class="container">
      <p class="eyebrow anim anim-up">{tl(copy.valuesEyebrow)}</p>
      <h2 class="big-statement reveal-lines">
        <span class="line"><span style="--i:0">{tl(copy.valuesLine1)}</span></span>
        <span class="line"><span style="--i:1">{tl(copy.valuesLine2a)}<em class="holo-text">{tl(copy.valuesLine2b)}</em>{tl(copy.valuesLine2c)}</span></span>
        <span class="line"><span style="--i:2">{tl(copy.valuesLine3)}</span></span>
      </h2>
      <div class="values-grid">
        <div class="value-block anim anim-up" data-tilt="4">
          <span class="value-no">01</span>
          <h3>{tl(copy.value1Title)}</h3>
          <p>{tl(copy.value1Body)}</p>
        </div>
        <div class="value-block anim anim-up" style="--d:120ms" data-tilt="4">
          <span class="value-no">02</span>
          <h3>{tl(copy.value2Title)}</h3>
          <p>{tl(copy.value2Body)}</p>
        </div>
        <div class="value-block anim anim-up" style="--d:240ms" data-tilt="4">
          <span class="value-no">03</span>
          <h3>{tl(copy.value3Title)}</h3>
          <p>{tl(copy.value3Body)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ SECTORS (parallax) ============ -->
  <section class="section section--dark sectors-sec">
    <div class="container">
      <div class="sectors-head">
        <h2 class="section-title anim anim-up">{tl(copy.sectorsTitleA)}<br />{tl(copy.sectorsTitleB)}</h2>
        <p class="lead anim anim-up" style="--d:120ms">{tl(copy.sectorsLead)}</p>
      </div>
      <div class="sectors-stack">
        {
          sectors.map((s, i) => (
            <a href={localizePath(`/sectors/${s.slug}`, lang)} class="sec-tile hoverable anim anim-scale" style={`--d:${(i % 3) * 90}ms`}>
              <div class="sec-tile__img">
                <img src={s.image} alt={`Hologram for ${t(s.name, lang)} by Holoconnects`} data-parallax="0.08" loading="lazy" />
              </div>
              <div class="sec-tile__veil"></div>
              <div class="sec-tile__txt">
                <span class="sec-tile__no">0{i + 1}</span>
                <h3>{tl(s.name)}</h3>
                <p>{tl(s.blurb)}</p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ TESTIMONIALS ============ -->
  <section class="section quote-sec">
    <div class="container">
      <div class="quote-head" data-reveal>
        <p class="eyebrow">{tl(copy.quoteEyebrow)}</p>
        <h2 class="section-title">{tl(copy.quoteTitleA)}<br /><span class="holo-text">{tl(copy.quoteTitleB)}</span></h2>
      </div>
      <div class="quote-grid">
        {
          testimonials.map((tm, i) => (
            <figure class="tcard anim anim-up" style={`--d:${i * 90}ms`} data-tilt="4">
              <div class="tcard__media">
                <img src={tm.image} alt={`Holoconnects hologram project, ${t(tm.role, lang)}`} loading="lazy" />
              </div>
              <blockquote>&ldquo;{tm.quote}&rdquo;</blockquote>
              <figcaption>
                <strong>{tm.name}</strong>
                <small>{tl(tm.role)}</small>
              </figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <Support lang={lang} />

  <CtaSection lang={lang} />
</Base>

<style>
  /* ============ HERO ============ */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: #050507;
    color: #fff;
    overflow: hidden;
  }
  .hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }
  .hero-mesh {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      radial-gradient(55% 65% at 82% 40%, rgba(234, 153, 20, 0.25), transparent 60%),
      radial-gradient(45% 55% at 12% 85%, rgba(200, 120, 0, 0.14), transparent 60%),
      linear-gradient(95deg, rgba(5, 5, 7, 0.92) 18%, rgba(5, 5, 7, 0.45) 46%, transparent 66%),
      radial-gradient(120% 100% at 50% 0%, transparent 40%, rgba(5, 5, 7, 0.6) 100%);
    animation: meshDrift 14s ease-in-out infinite alternate;
  }
  @keyframes meshDrift {
    to { transform: translate3d(-3%, 2%, 0) scale(1.08); }
  }
  .hero-scan {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: repeating-linear-gradient(
      to bottom,
      rgba(255, 255, 255, 0.025) 0px,
      rgba(255, 255, 255, 0.025) 1px,
      transparent 1px,
      transparent 4px
    );
    mix-blend-mode: overlay;
    opacity: 0.5;
  }
  .hero-content {
    position: relative;
    z-index: 3;
    max-width: 1180px;
  }
  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    padding: 0.55rem 1.05rem;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 100px;
    margin-bottom: 1.8rem;
    backdrop-filter: blur(6px);
    opacity: 0;
    animation: fadeDown 0.9s var(--ease) 0.1s forwards;
  }
  .hero-tag-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--grad-gold);
    box-shadow: 0 0 12px 2px rgba(234, 153, 20, 0.8);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    50% { opacity: 0.4; transform: scale(0.8); }
  }
  @keyframes fadeDown {
    from { opacity: 0; transform: translateY(-12px); }
    to { opacity: 1; transform: none; }
  }

  .hero-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.6rem, 6vw, 5.4rem);
    line-height: 1.0;
    letter-spacing: -0.04em;
    margin: 0 0 1.6rem;
    color: #fff;
    max-width: 66vw;
    position: relative;
    z-index: 4;
  }
  .hero-title .kinetic {
    display: block;
    white-space: nowrap;
  }
  @media (max-width: 900px) {
    .hero-title { max-width: 100%; }
  }
  .hero-rotator {
    display: inline-grid;
    overflow: hidden;
    vertical-align: top;
    padding-bottom: 0.12em;
    white-space: nowrap;
  }
  .hero-rotator > span {
