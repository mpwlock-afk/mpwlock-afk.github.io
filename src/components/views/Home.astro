<!-- Holographic globe canvas -->
<script>
  function bootGlobe() {
  const canvas = document.getElementById("holo-canvas") as HTMLCanvasElement | null;
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  if (canvas && !reduce && !canvas.dataset.booted) {
    canvas.dataset.booted = "1";
    const ctx = canvas.getContext("2d")!;
    let w = 0,
      h = 0,
      dpr = Math.min(window.devicePixelRatio || 1, 2);

    type P = { x: number; y: number; z: number };
    const N = 520;
    const pts: P[] = [];
    for (let i = 0; i < N; i++) {
      // fibonacci sphere
      const phi = Math.acos(1 - (2 * (i + 0.5)) / N);
      const theta = Math.PI * (1 + Math.sqrt(5)) * i;
      pts.push({
        x: Math.sin(phi) * Math.cos(theta),
        y: Math.sin(phi) * Math.sin(theta),
        z: Math.cos(phi),
      });
    }

    const resize = () => {
      w = canvas.clientWidth;
      h = canvas.clientHeight;
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    };
    resize();
    window.addEventListener("resize", resize);

    let mx = 0,
      my = 0,
      tx = 0,
      ty = 0;
    window.addEventListener("mousemove", (e) => {
      tx = (e.clientX / window.innerWidth - 0.5) * 0.6;
      ty = (e.clientY / window.innerHeight - 0.5) * 0.6;
    });

    let rot = 0;
    const render = () => {
      ctx.clearRect(0, 0, w, h);
      mx += (tx - mx) * 0.05;
      my += (ty - my) * 0.05;
      rot += 0.0016;

      const cx = w * (w < 720 ? 0.6 : 0.86);
      const cy = h * (w < 720 ? 0.24 : 0.52);
      const R = Math.min(w, h) * (w < 720 ? 0.42 : 0.36);

      const cosY = Math.cos(rot + mx),
        sinY = Math.sin(rot + mx);
      const cosX = Math.cos(my * 0.6),
        sinX = Math.sin(my * 0.6);

      const proj = pts.map((p) => {
        let x = p.x * cosY - p.z * sinY;
        let z = p.x * sinY + p.z * cosY;
        let y = p.y * cosX - z * sinX;
        z = p.y * sinX + z * cosX;
        const persp = 1 / (1.8 - z);
        return { sx: cx + x * R * persp, sy: cy + y * R * persp, z, persp };
      });

      // connection lines
      for (let i = 0; i < proj.length; i += 3) {
        for (let j = i + 1; j < Math.min(i + 14, proj.length); j++) {
          const a = proj[i],
            b = proj[j];
          const dx = a.sx - b.sx,
            dy = a.sy - b.sy;
          const d2 = dx * dx + dy * dy;
          if (d2 < 70 * 70) {
            const al = (1 - d2 / (70 * 70)) * 0.16 * ((a.z + b.z) / 2 + 1);
            ctx.strokeStyle = `rgba(234,153,20,${Math.max(al, 0)})`;
            ctx.beginPath();
            ctx.moveTo(a.sx, a.sy);
            ctx.lineTo(b.sx, b.sy);
            ctx.stroke();
          }
        }
      }
      // points
      for (const p of proj) {
        const a = (p.z + 1) / 2;
        const r = 0.6 + a * 1.8;
        ctx.beginPath();
        ctx.fillStyle = `rgba(${255},${180 + a * 40},${120 + a * 60},${0.25 + a * 0.6})`;
        ctx.arc(p.sx, p.sy, r, 0, Math.PI * 2);
        ctx.fill();
      }
      requestAnimationFrame(render);
    };
    render();
  }
  }
  bootGlobe();
  document.addEventListener("astro:page-load", bootGlobe);
</script>
