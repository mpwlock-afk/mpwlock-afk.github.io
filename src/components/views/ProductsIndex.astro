---
// Products listing — single source for both locales. Render via the thin route
// files src/pages/products/index.astro (en) and src/pages/nl/products/index.astro (nl).
import Base from "../../layouts/Base.astro";
import CtaSection from "../CtaSection.astro";
import { products } from "../../data/site";
import { t, localizePath, type Lang } from "../../i18n/ui";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

// Size-range lineup. Heights are true real-world ratios vs the 86" flagship.
// `img.black` / `img.white` get filled with the uniform renders; once both
// colours exist for every size, the colour switch turns on automatically.
const sizes = [
  { label: '22"', name: "Mini", ratio: 0.3, solid: false, img: { black: "/images/holobox-black.png", white: "" } },
  { label: '43"', name: "The 43", ratio: 0.52, solid: false, img: { black: "/images/holobox-43.png", white: "" } },
  { label: '75"', name: "The 75", ratio: 0.87, solid: false, img: { black: "/images/holobox-black.png", white: "" } },
  { label: '86"', name: "Flagship", ratio: 1.0, solid: false, img: { black: "/images/holobox-black.png", white: "" } },
];
const hasWhite = sizes.every((s) => s.img.white);
const hasBlack = sizes.every((s) => s.img.black);

// Page copy. NL is a first-pass translation — see TODO(native-review) markers.
const copy = {
  meta: {
    title: { en: "Products — Holoconnects", nl: "Producten — Holoconnects" },
    description: {
      en: "Explore the Holoconnects holographic display range: Holobox, Holobox Mini, The 43 and Hologrid. Life-size holographic displays from 22 to 86 inch.",
      // TODO(native-review): marketing tone
      nl: "Ontdek het holografische displaygamma van Holoconnects: Holobox, Holobox Mini, The 43 en Hologrid. Levensgrote holografische displays van 22 tot 86 inch.",
    },
  },
  eyebrow: { en: "Our products", nl: "Onze producten" },
  h1a: { en: "The hologram", nl: "Het hologram" },
  h1b: { en: "product range.", nl: "productgamma." },
  lead: {
    en: 'One platform for every display, from a 22" tabletop to the 86" life-size Holobox.',
    // TODO(native-review): marketing tone
    nl: 'Eén platform voor elk display, van een 22"-tafelmodel tot de 86" levensgrote Holobox.',
  },
  rangeEyebrow: { en: "The range", nl: "Het gamma" },
  rangeTitleA: { en: "One Holobox.", nl: "Eén Holobox." },
  rangeTitleB: { en: "Four sizes.", nl: "Vier maten." },
  rangeLead: {
    en: 'From a 22" tabletop to an 86" life-size flagship, the same holographic magic scaled to your space.',
    // TODO(native-review): marketing tone
    nl: 'Van een 22"-tafelmodel tot een 86" levensgroot vlaggenschip, dezelfde holografische magie geschaald naar uw ruimte.',
  },
  colorAria: { en: "Holobox colour", nl: "Holobox-kleur" },
  colorBlack: { en: "Midnight Black", nl: "Midnight Black" },
  colorWhite: { en: "Starlight White", nl: "Starlight White" },
  altLabel: { en: "render coming", nl: "render volgt" },
  sizeAlt: {
    en: (label: string) => `Holobox ${label} holographic display`,
    nl: (label: string) => `Holobox ${label} holografisch display`,
  },
  foot: {
    en: 'Heights shown to scale · 21.5" · 43" · 75" · 86"',
    nl: 'Hoogtes op schaal weergegeven · 21,5" · 43" · 75" · 86"',
  },
  prodImgAlt: {
    en: (name: string) => `${name} holographic display by Holoconnects`,
    nl: (name: string) => `${name} holografisch display van Holoconnects`,
  },
  explore: {
    en: (name: string) => `Explore ${name}`,
    nl: (name: string) => `Ontdek ${name}`,
  },
} as const;

const tl = (v: { en: string; nl: string }) => t(v, lang);
---

<Base lang={lang} title={tl(copy.meta.title)} description={tl(copy.meta.description)}>
  <section class="page-hero section--dark">
    <div class="container">
      <p class="eyebrow anim anim-up">{tl(copy.eyebrow)}</p>
      <h1 class="display anim anim-up" style="--d:80ms">{tl(copy.h1a)}<br /><span class="holo-text">{tl(copy.h1b)}</span></h1>
      <p class="lead measure anim anim-up" style="--d:160ms">{tl(copy.lead)}</p>
    </div>
  </section>

  <section class="section section--dark sizerange">
    <div class="container">
      <div class="block-head center" data-reveal>
        <p class="eyebrow">{tl(copy.rangeEyebrow)}</p>
        <h2 class="section-title">{tl(copy.rangeTitleA)}<br /><span class="holo-text">{tl(copy.rangeTitleB)}</span></h2>
        <p class="lead measure center">{tl(copy.rangeLead)}</p>
      </div>

      {(hasWhite && hasBlack) && (
        <div class="colorswitch" role="tablist" aria-label={tl(copy.colorAria)}>
          <button class="colorswitch__btn is-active" data-color="black" role="tab">{tl(copy.colorBlack)}</button>
          <button class="colorswitch__btn" data-color="white" role="tab">{tl(copy.colorWhite)}</button>
        </div>
      )}

      <div class="sizeline" data-reveal>
        {
          sizes.map((s) => (
            <div class="sizeunit" style={`--h:${s.ratio}`}>
              <div class={`sizeunit__box ${s.solid ? "is-solid" : ""}`}>
                {s.img.black || s.img.white ? (
                  <img
                    src={s.img.black || s.img.white}
                    data-black={s.img.black}
                    data-white={s.img.white}
                    alt={copy.sizeAlt[lang](s.label)}
                    loading="lazy"
                  />
                ) : (
                  <div class="sizeunit__ph"><span>{s.label}</span><small>{tl(copy.altLabel)}</small></div>
                )}
              </div>
              <span class="sizeunit__label">{s.label}</span>
            </div>
          ))
        }
      </div>
      <p class="sizeline__foot">{tl(copy.foot)}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="prod-list">
        {
          products.map((p, i) => (
            <article class="prow" data-reveal>
              <div class={`prow-media ${i % 2 === 1 ? "is-right" : ""}`}>
                <img src={p.image} alt={copy.prodImgAlt[lang](p.name)} loading="lazy" />
              </div>
              <div class="prow-body">
                <p class="pill">{t(p.tagline, lang)}</p>
                <h2>{p.name}</h2>
                <p class="text-muted">{t(p.summary, lang)}</p>
                <a href={localizePath(`/products/${p.slug}`, lang)} class="btn btn--primary">{copy.explore[lang](p.name)}</a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <CtaSection lang={lang} />
</Base>

<style>
  .page-hero {
    padding-top: clamp(8rem, 14vw, 12rem);
    padding-bottom: clamp(4rem, 8vw, 7rem);
  }
  .page-hero .lead {
    margin-top: 1.4rem;
  }
  .prod-list {
    display: flex;
    flex-direction: column;
    gap: clamp(3rem, 7vw, 6rem);
  }
  .prow {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }
  .prow-media {
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: radial-gradient(circle at 50% 40%, #1a1a1d, #0a0a0a);
    aspect-ratio: 5 / 4;
    display: grid;
    place-items: center;
  }
  .prow-media.is-right {
    order: 2;
  }
  .prow-media img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 2rem;
  }
  .prow-body {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }
  .prow-body h2 {
    font-size: clamp(2rem, 4vw, 3rem);
  }
  .prow-body .btn {
    margin-top: 0.6rem;
  }
  @media (max-width: 760px) {
    .prow {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .prow-media.is-right {
      order: 0;
    }
  }

  /* ===== Size range ===== */
  .sizerange .block-head { margin-inline: auto; margin-bottom: clamp(2rem, 4vw, 3rem); }

  .colorswitch {
    display: flex;
    gap: 0.3rem;
    width: max-content;
    margin: 0 auto 2.5rem;
    padding: 0.3rem;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 100px;
    background: rgba(255, 255, 255, 0.04);
  }
  .colorswitch__btn {
    border: 0;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: #b4b4bd;
    padding: 0.6rem 1.2rem;
    border-radius: 100px;
    background: transparent;
    transition: color 0.3s var(--ease), background 0.3s var(--ease);
  }
  .colorswitch__btn.is-active {
    color: #0a0a0a;
    background: #fff;
  }

  .sizeline {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: clamp(1rem, 4vw, 3.5rem);
    height: clamp(280px, 44vh, 460px);
    padding-bottom: 1.5rem;
    position: relative;
  }
  .sizeline::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: 1.5rem;
    transform: translateX(-50%);
    width: min(92%, 980px);
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(234, 153, 20, 0.5), transparent);
  }
  .sizeunit {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    height: 100%;
  }
  .sizeunit__box {
    height: calc(var(--h) * 100%);
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }
  .sizeunit__box img {
    height: 100%;
    width: auto;
    object-fit: contain;
    object-position: bottom center;
    -webkit-box-reflect: below 2px linear-gradient(transparent 62%, rgba(255, 255, 255, 0.12));
  }
  .sizeunit__box.is-solid img {
    -webkit-box-reflect: none;
    border-radius: 4px;
  }
  .sizeunit__ph {
    height: 100%;
    aspect-ratio: 2 / 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    border: 1.5px dashed rgba(255, 255, 255, 0.2);
    border-radius: 10px;
    color: rgba(255, 255, 255, 0.45);
  }
  .sizeunit__ph span { font-family: var(--font-display); font-size: 1.4rem; color: #fff; }
  .sizeunit__ph small { font-size: 0.6rem; letter-spacing: 0.16em; text-transform: uppercase; }
  .sizeunit__label {
    margin-top: 1.1rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: #0a0a0a;
    background: var(--grad-gold);
    padding: 0.3rem 0.8rem;
    border-radius: 100px;
  }
  .sizeline__foot {
    text-align: center;
    margin-top: 1.5rem;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: #76767e;
  }
  @media (max-width: 560px) {
    .sizeline { gap: 0.6rem; height: 300px; }
    .sizeunit__label { font-size: 0.62rem; padding: 0.25rem 0.55rem; }
  }
</style>

<script>
  function wireColorSwitch() {
    const sw = document.querySelector(".colorswitch");
    if (!sw || (sw as HTMLElement).dataset.wired) return;
    (sw as HTMLElement).dataset.wired = "1";
    const imgs = Array.from(document.querySelectorAll<HTMLImageElement>(".sizeunit__box img"));
    sw.querySelectorAll<HTMLButtonElement>(".colorswitch__btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        sw.querySelectorAll(".colorswitch__btn").forEach((b) => b.classList.remove("is-active"));
        btn.classList.add("is-active");
        const color = btn.dataset.color;
        imgs.forEach((img) => {
          const next = color === "white" ? img.dataset.white : img.dataset.black;
          if (next) img.src = next;
        });
      });
    });
  }
  wireColorSwitch();
  document.addEventListener("astro:page-load", wireColorSwitch);
</script>
